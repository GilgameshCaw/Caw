# Local diag scripts dropped onto the VPS or developer machines during
# investigation. Real diag scripts that should be committed start with
# something descriptive (rescan-, seed-, deactivate-); diag-* is a
# convention for transient debugging that doesn't belong in git, and
# leaving them untracked has been a recurring deploy blocker when a
# committed counterpart later lands at the same path.
client/scripts/diag-*.ts
client/scripts/diag-*.js

# Operator-installed cron wrapper script. Generated by cli's
# setupStakeLedgerCron() at install time; not portable across hosts.
/scripts/reseed-stake-ledger.sh

# Quick scratch reply / message drafts saved while triaging incidents.
# Local-only.
/zin-reply.txt

# PM2 ecosystem files (machine-specific, generated by installer; VPS regenerates its own)
ecosystem.config.cjs
ecosystem.config.js

# Redis append-only-file persistence (recreated on each redis-server start)
*.aof

# Build/deploy timestamp marker, touched at repo root by the CLI / deploy
# scripts to record when the last update ran. Empty file, machine-local.
latest.timestamp

# Per-install addresses.ts. Written by the CLI install step (resolves the
# operator's chosen client to the right per-chain addresses from
# client/src/abi/deployments.ts). The committed addresses.ts.example is the
# pre-multi-chain snapshot; the canonical manifest lives in deployments.ts.
client/src/abi/addresses.ts

# Generated by `solidity/zk/sig-recovery/script/.../digest-fixtures.rs` at
# test-time. The fixture's domain hash is keyed to the helper contract's
# deployed address (which differs per run), so committing it would create
# spurious diffs every CI run. The Hardhat test regenerates on each run.
solidity/test/zk-digest-fixtures.json

# Claude Code per-user state. settings.local.json holds machine-specific
# permission allow-lists; scheduled_tasks.lock is a PID lockfile;
# worktrees/ are agent-local git worktrees with absolute gitdir paths.
# None of it is portable. If we ever want team-wide Claude Code config,
# add a separate `.claude/settings.json` (no .local) explicitly.
.claude/

# Drafts of messages/posts written for the user to copy out (pbcopy).
# Local-only scratch — not part of the codebase.
/messages/

# HTML visualizations / decision aids drafted for the user to open locally.
# Local-only scratch — not part of the codebase.
/visualizations/

