# Database
# V2 schema (Network rename, per-fee ceilings, profileId, MarketplacePayout).
# Create with `createdb caw_v2_local` first, then `npx prisma db push`.
# V1 DB (typically caw_local/caw_dev) remains untouched.
# See docs/V2_DB_SETUP.md for the full setup walkthrough.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/caw_v2_local

# L1 RPC URLs (Ethereum Sepolia for testnet, Ethereum Mainnet for production)
L1_RPC_URL="wss://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY"
L1_RPC_URL_HTTP="https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY"

# L2 RPC URLs (Base Sepolia for testnet, Base Mainnet for production)
L2_RPC_URL="wss://base-sepolia.infura.io/ws/v3/YOUR_API_KEY"
L2_RPC_URL_HTTP="https://base-sepolia.infura.io/v3/YOUR_API_KEY"

# Ethereum Mainnet RPC (for Uniswap price feeds)
ETH_MAINNET_RPC_URL="https://mainnet.infura.io/v3/YOUR_API_KEY"

# Validator private key (for submitting transactions on-chain)
VALIDATOR_PRIVATE_KEY="0x..."

# ─── Sponsor server (EIP-7702 / SmartEOA onboarding) ────────────────────────
# Set SPONSOR_ENABLED=1 to activate. The other vars are required when enabled.
SPONSOR_ENABLED=0
# Hot wallet that pays gas and holds CAW for sponsored mints/deposits.
# Can be the same key as VALIDATOR_PRIVATE_KEY in small deployments, but a
# separate key is recommended so L1 and L2 budgets are isolated.
SPONSOR_HOT_WALLET_PRIVATE_KEY="0x..."
# L1 RPC URL for the sponsor service. Defaults to L1_RPC_URL_HTTP if unset.
SPONSOR_L1_RPC_URL=
# L1 chain ID (e.g. 11155111 for Sepolia, 1 for mainnet). Resolved from RPC
# if unset — costs one extra eth_chainId call at startup.
L1_CHAIN_ID=11155111
# SmartEOA implementation address (deployed once per L1; all users share it).
# Set after deploy. Zero address disables the sponsored bootstrap path.
SMART_EOA_ADDRESS="0x0000000000000000000000000000000000000000"
# Minimum CAW (in wei) a user must deposit to use sponsored bootstrap.
# Prevents spam accounts. Default: 1_000_000 * 1e18 (=1M CAW, 8-char name cost).
SPONSOR_MIN_DEPOSIT_CAW=1000000000000000000000000
# Maximum CAW (in wei) allowed per bootstrap/deposit call. Caps per-call sponsor
# CAW exposure so a single crafted request cannot drain the full allowance.
# Default: 10_000_000 * 1e18 (=10M CAW). (M-1 audit fix)
SPONSOR_MAX_DEPOSIT_CAW=10000000000000000000000000
# Maximum LayerZero fee (in wei ETH) allowed per call. Caps per-call sponsor ETH
# exposure. Default: 5_000_000_000_000_000 (=0.005 ETH). (M-2 audit fix)
SPONSOR_MAX_LZ_FEE_WEI=5000000000000000

# Prisma
PRISMA_QUERY_ENGINE_TYPE=binary

# Giphy API key (for GIF search)
GIPHY_API_KEY="YOUR_GIPHY_API_KEY"

# Sentry error reporting (optional). Leave blank to disable.
SENTRY_DSN=

# OpenTelemetry tracing (optional). Point at the base URL of any OTLP/HTTP
# collector — typically a self-hosted SigNoz instance on :4318. The exporter
# appends /v1/traces. Leave blank to disable (zero overhead).
# Example: OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# Service name shown in the SigNoz UI. The CLI auto-derives this from your
# domain (or clientId fallback) so multiple CAW instances sharing one
# collector show up as distinct services. Override here if you want a
# different name.
OTEL_SERVICE_NAME=

# X (Twitter) OAuth 2.0 — used by /api/verify/x to link a CAW profile to an
# X account and pull a bucketed follower count. Register an app at
# https://developer.twitter.com/en/portal/dashboard with OAuth 2.0 enabled
# (User authentication settings: Confidential client, type Web App). The
# callback URL is derived as ${INSTANCE_API_URL}/api/verify/x/callback —
# paste that exact URL into the X app's Callback URI field so they match.
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=

# Media storage backend. `local` (default) writes to public/uploads/ and
# serves via nginx. `filebase` writes to an S3-compatible Filebase bucket
# and serves via MEDIA_PUBLIC_URL_BASE (or directly from
# https://<bucket>.s3.filebase.io/ if MEDIA_PUBLIC_URL_BASE is unset).
MEDIA_STORAGE_BACKEND=local
# When MEDIA_STORAGE_BACKEND=filebase. Endpoint + region are pinned in code.
FILEBASE_ACCESS_KEY=
FILEBASE_SECRET=
FILEBASE_BUCKET=
# Optional: a CDN/proxy hostname that fronts Filebase (e.g.
# https://s.caw.social — keep it without a trailing slash). The path
# `/uploads/<kind>/<filename>` is appended verbatim. The proxy must map
# /uploads/* → bucket-name.s3.filebase.io/<FILEBASE_KEY_PREFIX>/*.
# `caw update` writes a matching nginx vhost when this is set.
MEDIA_PUBLIC_URL_BASE=
# Optional: bucket-side prefix to namespace this install's keys, so a
# single Filebase bucket can hold media for multiple deployments without
# collisions. Defaults to the hostname of SHORTURL_DOMAIN
# (e.g. `test.caw.social`). The reverse-proxy injects this on the wire,
# so it doesn't appear in the public URL.
FILEBASE_KEY_PREFIX=
