model PriceSnapshot {
  id        Int      @id @default(autoincrement())
  token     String // "caw" or "eth"
  usdPrice  Float // Price in USD
  ethPrice  Float? // Price in ETH (for CAW only)
  createdAt DateTime @default(now())

  @@index([token, createdAt])
  @@index([createdAt])
}

/// Tracks every validator-submitted transaction for analytics
model ValidatorTx {
  id              Int      @id @default(autoincrement())
  txHash          String   @unique
  blockNumber     BigInt?
  txType          String   @default("processActions") // processActions | sessionRegister | sessionRevoke
  actionCount     Int // Number of actions in the batch (0 for session txs)
  actionBreakdown Json? // { CAW: 3, LIKE: 2, FOLLOW: 1, ... }
  gasUsed         String // Actual gas used (from receipt)
  gasPrice        String // Effective gas price (wei)
  ethCost         String // gasUsed * gasPrice in wei
  tipCaw          String // Total CAW tip earned from the batch
  tipEthValue     String // Tip converted to ETH (wei) at submission time
  profit          String // tipEthValue - ethCost (can be negative)
  validatorId     Int
  status          String   @default("confirmed") // confirmed | failed | reverted
  failReason      String?
  avgWaitMs       Int? // Avg time from TxQueue.createdAt to submission
  sessionUser     String? // Address of user who requested the session (for session txs)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([validatorId, createdAt])
  @@index([txType, createdAt])
}

/// Tracks every optimistic replication submission to the L2b archive.
/// Status transitions: confirmed → challenged → slashed (on fraud).
model ReplicationTx {
  id              Int      @id @default(autoincrement())
  txHash          String   @unique
  blockNumber     BigInt?
  clientId        Int
  checkpointId    Int // start checkpoint ID
  endCheckpointId Int? // end checkpoint ID (for multibatch, null = single)
  actionCount     Int      @default(256)
  gasUsed         String
  gasPrice        String
  ethCost         String
  totalCost       String
  status          String   @default("confirmed")
  failReason      String?
  submitter       String? // L2b address that submitted (lowercase hex)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([clientId, createdAt])
  @@index([submitter, createdAt])
}

/// Admin-configurable validator settings (DB-backed, overrides env vars)
model ValidatorSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Coordinates the fraud-challenge pipeline across multiple validator nodes
/// that share a database. A lock is claimed via INSERT...ON CONFLICT DO NOTHING
/// before sending a challenge or calling resolveChallenge, so only one node
/// does the work. `expiresAt` lets stale locks (node crashed mid-call) be
/// reclaimed. `kind` scopes the lock to a specific pipeline stage so, for
/// example, the relay stage doesn't block the resolve stage.
model ChallengeLock {
  /// Composite natural key built as "{kind}:{submissionId}:{checkpointId}"
  /// so a single INSERT can claim atomically.
  key          String   @id
  kind         String // e.g. "relay", "resolve", "slashIncoherent"
  submissionId BigInt
  checkpointId BigInt // unused for submission-level locks; stored as 0
  holder       String // validator address or instance ID
  claimedAt    DateTime @default(now())
  expiresAt    DateTime
  outcome      String? // "success", "error", null while in-flight
  txHash       String?

  @@index([kind, submissionId])
  @@index([expiresAt])
}

