  @@index([status])
  @@index([postId])
  @@index([reporterId])
  @@index([reporterId, postId])
  @@index([postAuthorId])
  @@index([createdAt])
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

/// Audit trail for moderator-tier mutations (hide caw, ban user, etc.).
/// Append-only — never updated, never deleted. Lets admins answer "who
/// hid this caw and why" without grep-archaeology of server logs.
model ModeratorAction {
  id           Int      @id @default(autoincrement())
  /// Tokenid of the moderator who performed the action. NULL means the
  /// action was taken by the password-cookie admin (no wallet identity
  /// available in that path).
  actorTokenId Int?
  /// Free-form action verb: "hide_caw", "unhide_caw", "ban_user", etc.
  /// Kept as a string instead of an enum so we can add new verbs without
  /// migrations during early iteration.
  type         String
  targetCawId  Int?
  targetUserId Int?
  reason       String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("ModeratorActor", fields: [actorTokenId], references: [tokenId], onDelete: SetNull)

  @@index([actorTokenId, createdAt])
  @@index([type, createdAt])
  @@index([targetCawId])
  @@index([targetUserId])
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  EXPLICIT
  ILLEGAL_HARMFUL
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

model BugReport {
  id           Int          @id @default(autoincrement())
  type         String       @default("bug") // "bug" or "feature"
  userId       Int? // Reporter's tokenId (null if not signed in)
  username     String?
  stakedAmount String? // Staked CAW amount as string
  description  String
  imageUrls    String? // Pipe-separated image URLs
  page         String? // URL/route where the bug was encountered
  userAgent    String?
  status       ReportStatus @default(PENDING)
  resolution   String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([type])
