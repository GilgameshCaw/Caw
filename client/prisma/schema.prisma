enum MarketListingType {
  FIXED
  DUTCH_AUCTION
  ENGLISH_AUCTION
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  WITHDRAWN
}

model MarketplaceOffer {
  id             Int                         @id @default(autoincrement())
  offerId        Int                         @unique // on-chain offer ID
  tokenId        Int
  offerer        String // wallet address
  paymentToken   String // "ETH", "CAW", "WETH", "USDC", "USDT"
  paymentAddress String // token contract address
  amount         String // offer amount in wei
  expiry         DateTime
  status         OfferStatus                 @default(ACTIVE)
  username       String
  txHash         String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  notifications  Notification[]
  dismissals     MarketplaceOfferDismissal[]

