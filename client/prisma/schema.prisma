  pendingUnpin Boolean  @default(false)
  createdAt    DateTime @default(now())
  caw          Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@unique([userId, cawId])
  @@index([userId, createdAt])
  @@index([cawId])
}

/// Indexed mirror of CawNameL2.sessions[owner][sessionKey] state.
/// Written by the event indexer listening for SessionCreated / SessionRevoked
/// on L2. Read by /api/actions to validate session-key-signed submissions
/// without a live RPC call per action.
model SessionKey {
  id               Int       @id @default(autoincrement())
  ownerAddress     String
  sessionAddress   String
  expiry           BigInt
  scopeBitmap      Int
  spendLimit       String
  spent            String    @default("0")
  revokedAt        DateTime?
  lastSyncedAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  perActionTipRate String    @default("0")
  profileId        Int       @default(0)

  @@unique([ownerAddress, sessionAddress])
  @@index([ownerAddress])
  @@index([sessionAddress])
  @@index([profileId])
}

/// X (Twitter) account link, scoped to a wallet address. The /api/verify/x
/// OAuth flow proves the wallet controls the X handle; we capture a bucketed
/// follower count once at link time (and on user-initiated refresh) and
/// discard the OAuth tokens.
///
/// Wallet-scoped (not per-User) because every CAW profile owned by the
/// linked wallet inherits the link. xUserId is X's stable id (handles can
/// change) and is the conflict key for first-link-wins enforcement at the
/// DB level. Per-profile show/hide is on User.xBadgeVisible.
///
/// Address is stored lowercased — read paths and write paths both
/// normalize so the unique key behaves like a case-insensitive index.
model WalletXLink {
  id                 Int      @id @default(autoincrement())
  address            String   @unique
  xUserId            String   @unique
  xHandle            String
  xFollowerBucket    Int?
  linkedAt           DateTime @default(now())
  followersUpdatedAt DateTime @default(now())

  @@index([xHandle])
}

/// Per-user CAW balance change ledger written by the StakeLedger
/// snapshotter. Mirrors CawProfileL2.cawOwnership state transitions
/// bit-for-bit using TS bigint. One row per touched user per action
/// (sender + recipient if any), plus rows for L1->L2 deposits and
/// withdrawals. Communal rewards are computed at query time from
/// RewardMultiplierSnapshot deltas, not stored as rows here.
///
/// All NUMERIC(78,0) values are stored as String to avoid precision
/// loss across the JSON layer — same pattern as User.onChainStakeWei.
model CawOwnershipSnapshot {
  id                  BigInt   @id @default(autoincrement())
  tokenId             Int
  blockNumber         BigInt
  blockTimestamp      DateTime
  txHash              String
  logIndex            Int
  actionIndex         Int?
  ownership           String
  multiplier          String
  balance             String
  delta               String
  reason              String
  actionType          String?
  counterpartyTokenId Int?
  createdAt           DateTime @default(now())

  @@index([tokenId, blockTimestamp])
  @@index([blockTimestamp])
}

/// One row per global rewardMultiplier change. Used to attribute
/// communal rewards to a user across a window:
/// communal[user, t0..t1] = SUM over events e in window of
/// cawOwnership_at(user, e.timestamp) * (multiplierAfter - multiplierBefore) / 1e18
model RewardMultiplierSnapshot {
  blockNumber      BigInt
  txHash           String
  logIndex         Int
  actionIndex      Int
  blockTimestamp   DateTime
  multiplierBefore String
  multiplierAfter  String
  communalAmount   String
  /// Resolved action type that triggered this distribution (CAW,
  /// LIKE, RECAW, FOLLOW, TIP, OTHER). Lets the activity chart break
  /// down "CAW distributed to stakers" by action type at the system
  /// level. Nullable for legacy rows from before this column existed.
  actionType       String?

  @@id([blockNumber, logIndex, actionIndex])
  @@index([blockTimestamp])
}

/// Persisted running state of the StakeLedger snapshotter so a
/// process restart resumes without replaying from genesis.
model StakeLedgerState {
  totalCaw     String
  multiplier   String
  lastBlock    BigInt
  lastLogIndex Int
  updatedAt    DateTime @default(now())
  networkId    Int      @id
}

/// Latest cawOwnership[tokenId] mirroring contract state. Lets the
/// snapshotter cold-start without a full CawOwnershipSnapshot scan,
/// and gives the daily reconciler a cheap target to compare against
/// the on-chain cawOwnership(tokenId) read.
model CawOwnershipCurrent {
  tokenId   Int      @id
  ownership String
  updatedAt DateTime @default(now())
}

