generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RawEvent {
  id              Int      @id @default(autoincrement())
  chainId         Int
  blockNumber     BigInt
  logIndex        Int
  transactionHash String
  parentHash      String
  data            Json
  topics          Json
  contractAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Action          Action[]

  @@unique([blockNumber, logIndex, transactionHash])
  @@index([chainId, blockNumber, logIndex])
}

model User {
  id                      Int                         @id
  address                 String                      @default("")
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  cawCount                Int                         @default(0)
  recawCount              Int                         @default(0)
  followerCount           Int                         @default(0)
  followingCount          Int                         @default(0)
  image                   String?
  likedCount              Int                         @default(0)
  likesReceivedCount      Int                         @default(0)
  tokenId                 Int                         @unique
  username                String                      @unique
  avatarUrl               String?
  defaultAvatarId         Int                         @default(0)
  bio                     String?
  coverPhotoUrl           String?
  displayName             String?
  location                String?
  profileUpdatePending    Boolean                     @default(false)
  profileSource           String                      @default("onchain")
  website                 String?
  onboardingStep          Int                         @default(0)
  lastStakedAt            DateTime?
  pendingDepositAmount    String?
  onChainStakeWei         String?
  onChainStakeUpdatedAt   DateTime?
  lastViewedOffersAt      DateTime?
  xBadgeVisible           Boolean                     @default(true)
  preferredLanguage       String?
  autoTranslate           Boolean                     @default(false)
  pinnedCawCount          Int                         @default(0)
  role                    UserRole                    @default(USER)
  notificationTipRequired Int                         @default(0)
  blocksReceived          Block[]                     @relation("BlocksReceived")
  blocksGiven             Block[]                     @relation("BlocksGiven")
  bookmarks               Bookmark[]
  caws                    Caw[]
  dmIdentity              DmIdentity?
  followers               Follow[]                    @relation("Follower")
  follows                 Follow[]                    @relation("Following")
  likes                   Like[]
  offerDismissals         MarketplaceOfferDismissal[]
  moderatorActions        ModeratorAction[]           @relation("ModeratorActor")
  notificationsSent       Notification[]              @relation("NotificationActor")
  notificationsReceived   Notification[]              @relation("NotificationRecipient")
  notificationGroups      NotificationGroup[]
  pinnedCaws              PinnedCaw[]
  replies                 Reply[]
  scheduledCaws           ScheduledCaw[]
  tipsReceived            Tip[]                       @relation("TipsReceived")
  tipsSent                Tip[]                       @relation("TipsSent")
  votes                   Vote[]

  @@index([address])
  @@index([cawCount, followerCount])
  @@index([role])
}

model Caw {
  id             Int            @id @default(autoincrement())
  userId         Int
  content        String
  action         ActionType
  createdAt      DateTime       @default(now())
  originalCawId  Int?
  cawonce        Int
  commentCount   Int            @default(0)
  recawCount     Int            @default(0)
  likeCount      Int            @default(0)
  updatedAt      DateTime       @updatedAt
  hasImage       Boolean        @default(false)
  hasVideo       Boolean        @default(false)
  sourceLanguage String?
  imageData      String?
  status         CawStatus      @default(SUCCESS)
  reason         String?
  videoData      String?
  viewCount      Int            @default(0)
  bookmarkCount  Int            @default(0)
  bookmarks      Bookmark[]
  parent         Caw?           @relation("CawToRecaws", fields: [originalCawId], references: [id])
  recaws         Caw[]          @relation("CawToRecaws")
  user           User           @relation(fields: [userId], references: [tokenId])
  hashtags       CawHashtag[]
  likes          Like[]
  notifications  Notification[]
  pinnedBy       PinnedCaw[]
  poll           Poll?
  repliesOnThis  Reply[]        @relation("RepliesOnCaw")
  isReplyTo      Reply[]        @relation("ReplyCaw")
  tips           Tip[]

  @@unique([userId, cawonce])
  @@index([userId, action, createdAt])
  @@index([status, createdAt])
  @@index([originalCawId])
  @@index([originalCawId, action])
  @@index([status, userId])
  @@index([userId, status, createdAt])
}

model Poll {
  id           Int       @id @default(autoincrement())
  cawId        Int       @unique
  /// When voting closes. Computed at indexer-write time from the caw's
  /// block timestamp plus the duration in the ::pd:<dur>:: marker
  /// sidecar. NULL means the poll has no expiry (legacy polls created
  /// before the duration sidecar was added).
  endsAt       DateTime?
  options      String[]
  optionImages String[]  @default([])
  /// When true, voters can pick any subset of options (checkbox UI;
  /// each vote action toggles one option). Encoded on-chain via the
  /// `::pm::` marker sidecar. Default false = single-select (radio UI;
  /// each vote replaces the prior choice). Legacy polls created
  /// before the sidecar always parse as single-select.
  multiSelect  Boolean   @default(false)
  totalVotes   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  caw          Caw       @relation(fields: [cawId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@index([cawId])
}

model Vote {
  id          Int      @id @default(autoincrement())
  pollId      Int
  voterId     Int
  optionIndex Int
  cawonce     Int
  pending     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  poll        Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  voter       User     @relation(fields: [voterId], references: [tokenId])

  @@unique([pollId, voterId, optionIndex])
  @@index([pollId, optionIndex])
  @@index([voterId])
}

model Like {
  userId    Int
  cawId     Int
  action    ActionType
  createdAt DateTime   @default(now())
  pending   Boolean    @default(false)
  updatedAt DateTime   @updatedAt
  id        Int        @id @default(autoincrement())
  caw       Caw        @relation(fields: [cawId], references: [id])
  user      User       @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId])
  @@index([cawId])
  @@index([cawId, action])
}

model Reply {
  id         Int      @id @default(autoincrement())
  userId     Int
  cawId      Int
  replyCawId Int
  pending    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  caw        Caw      @relation("RepliesOnCaw", fields: [cawId], references: [id])
  replyCaw   Caw      @relation("ReplyCaw", fields: [replyCawId], references: [id])
  user       User     @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId, replyCawId])
  @@index([cawId])
  @@index([cawId, pending])
  @@index([userId])
}

model Follow {
  id          Int        @id @default(autoincrement())
  followerId  Int
  followingId Int
  action      ActionType @default(FOLLOW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  status      CawStatus  @default(SUCCESS)
  follower    User       @relation("Follower", fields: [followerId], references: [tokenId])
  following   User       @relation("Following", fields: [followingId], references: [tokenId])

  @@unique([followerId, followingId])
  @@index([followerId, status])
  @@index([followingId, status])
  @@index([followerId, action, status])
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [tokenId])
  blocker   User     @relation("BlocksGiven", fields: [blockerId], references: [tokenId])

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model TxQueue {
  id                     Int      @id @default(autoincrement())
  payload                Json
  signedTx               String
  status                 String   @default("pending")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  senderId               Int
  reason                 String?
  pendingDepositTxHash   String?
  batchId                Int?
  cawonce                Int?
  clientVersion          String?
  clientOrigin           String?
  pendingQuickSignTxHash String?
  implicitTip            String?
  signerKind             String   @default("owner")

  @@index([senderId, status])
  @@index([batchId])
  @@index([signedTx])
}

model Action {
  id               Int        @id @default(autoincrement())
  rawEventId       Int
  chainId          Int
  senderId         Int
  cawonce          Int
  actionType       ActionType
  data             Json
  txHash           String?
  blockNumber      Int?
  submitterAddress String?
  validatorId      Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  rawEvent         RawEvent   @relation(fields: [rawEventId], references: [id])

  @@unique([chainId, senderId, cawonce])
  @@index([senderId])
  @@index([actionType, createdAt])
}

model Hashtag {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  displayName String?
  usageCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  caws        CawHashtag[]

  @@index([name])
  @@index([usageCount])
}

model CawHashtag {
  id        Int      @id @default(autoincrement())
  cawId     Int
  hashtagId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  caw       Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([cawId, hashtagId])
  @@index([hashtagId])
  @@index([cawId])
}

model ScheduledCaw {
  id           Int      @id @default(autoincrement())
  userId       Int
  content      String
  scheduledAt  DateTime
  status       String   @default("pending")
  publishedId  Int?
  imageData    String?
  hasImage     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  signedAction Json?
  cawonce      Int?
  threadId     String?
  threadIndex  Int?
  threadTotal  Int?
  user         User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@index([status, scheduledAt])
  @@index([userId, status, cawonce])
  @@index([threadId, threadIndex])
}

/// Persistent rollup bucket for notifications. Created lazily by the
/// notification write path: a new notification looks for an OPEN group
/// matching (userId, type, targetKey) — open means `isRead=false` AND
/// `lastEventAt` within the last 15 minutes — and joins it if found,
/// or starts a fresh group otherwise. The notifications-list read
/// path queries this table directly so rollup is O(group page size),
/// not O(raw notifications).
///
/// "targetKey" semantics per type:
/// LIKE / REPOST / QUOTE / REPLY / TIP / MENTION → cawId as string
/// OFFER → tokenId as string
/// FOLLOW → null (one global follow bucket per user)
/// ACTION_FAILED → null (each failure is its own row, ungrouped)
///
/// Marking a group read closes it: the next event on the same target
/// starts a fresh group so users can see "5 new likes since last
/// time" instead of one ever-growing rollup. A group stays open
/// indefinitely while unread — no time-based closure.
model NotificationGroup {
  id                   Int              @id @default(autoincrement())
  userId               Int
  type                 NotificationType
  /// Disambiguator within (userId, type). String so we can stuff
  /// cawId / offerId / etc. into the same column without per-type
  /// joins; null means "global for this type".
  targetKey            String?
  openedAt             DateTime         @default(now())
  /// Updated whenever a notification is added to this group. Drives
  /// the order on the feed (DESC).
  lastEventAt          DateTime         @default(now())
  isRead               Boolean          @default(false)
  /// Quick pointer to the most-recent member for renderer lead
  /// actor / caw thumbnail / offer payload. Updated on every join.
  latestNotificationId Int
  /// Confirmed-row count for the rollup. Updated atomically with
  /// notification inserts inside the same transaction.
  count                Int              @default(1)
  notifications        Notification[]
  user                 User             @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId, lastEventAt])
  @@index([userId, type, targetKey, isRead, lastEventAt])
}

model Notification {
  id            Int                @id @default(autoincrement())
  userId        Int
  actorId       Int
  type          NotificationType
  cawId         Int?
  offerId       Int?
  groupKey      String?
  /// Persistent NotificationGroup this row belongs to. Null only for
  /// rows created before the group-table migration; backfill flips
  /// them to a per-row synthetic group in the migration.
  groupId       Int?
  isRead        Boolean            @default(false)
  hidden        Boolean            @default(false)
  actionPayload Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  actor         User               @relation("NotificationActor", fields: [actorId], references: [tokenId], onDelete: Cascade)
  caw           Caw?               @relation(fields: [cawId], references: [id], onDelete: Cascade)
  group         NotificationGroup? @relation(fields: [groupId], references: [id])
  offer         MarketplaceOffer?  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user          User               @relation("NotificationRecipient", fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, hidden, createdAt])
  @@index([userId, type])
  @@index([userId, actorId, type])
  @@index([groupKey])
  @@index([userId, groupKey, createdAt])
}

model DmIdentity {
  id                   Int                       @id @default(autoincrement())
  userId               Int                       @unique
  walletAddress        String
  publicKey            String
  walletProof          String?
  dmPrivacy            DmPrivacy                 @default(EVERYONE)
  defaultDmReactions   String[]                  @default([])
  allowGroupInvites    Boolean                   @default(true)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  relayedWalletAddress String?
  revoked              Boolean                   @default(false)
  conversations        ConversationParticipant[]
  user                 User                      @relation(fields: [userId], references: [tokenId])
  invitesCreated       GroupInvite[]             @relation("GroupInviteCreator")
  sentMessages         Message[]                 @relation("MessageSender")
  reactions            MessageReaction[]
  recipientPayloads    MessageRecipientPayload[]

  @@index([walletAddress])
}

model Conversation {
  id            String                    @id @default(uuid())
  type          ConversationType          @default(DM)
  creatorId     Int
  name          String?
  avatarUrl     String?
  lastMessageAt DateTime?
  lastMessageId String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  participants  ConversationParticipant[]
  invites       GroupInvite[]
  messages      Message[]

  @@index([creatorId])
}

model ConversationParticipant {
  id             Int                           @id @default(autoincrement())
  conversationId String
  userId         Int
  joinedAt       DateTime                      @default(now())
  lastReadAt     DateTime?
  unreadCount    Int                           @default(0)
  status         ConversationParticipantStatus @default(ACCEPTED)
  role           ConversationParticipantRole   @default(MEMBER)
  leftAt         DateTime?
  conversation   Conversation                  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  identity       DmIdentity                    @relation(fields: [userId], references: [userId])

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@index([userId, status])
  @@index([conversationId, leftAt])
  @@index([userId, leftAt, status])
}

model Message {
  id                String                    @id @default(uuid())
  conversationId    String
  senderId          Int
  encryptedPayload  String?
  contentType       String                    @default("text")
  editHistory       String?
  systemPayload     Json?
  status            MessageStatus             @default(SENT)
  shadowBlocked     Boolean                   @default(false)
  senderSig         String?
  verifiedSender    Boolean?
  relayId           String?                   @unique
  replyToMessageId  String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  conversation      Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo           Message?                  @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies           Message[]                 @relation("MessageReplies")
  sender            DmIdentity                @relation("MessageSender", fields: [senderId], references: [userId])
  deletions         MessageDeletion[]
  reactions         MessageReaction[]
  receipts          MessageReceipt[]
  recipientPayloads MessageRecipientPayload[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToMessageId])
}

model MessageRecipientPayload {
  id               BigInt     @id @default(autoincrement())
  messageId        String
  recipientUserId  Int
  encryptedPayload String
  createdAt        DateTime   @default(now())
  message          Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient        DmIdentity @relation(fields: [recipientUserId], references: [userId], onDelete: Cascade)

  @@unique([messageId, recipientUserId])
  @@index([recipientUserId])
}

model GroupInvite {
  id              String       @id @default(uuid())
  token           String       @unique
  conversationId  String
  createdByUserId Int
  createdAt       DateTime     @default(now())
  expiresAt       DateTime
  maxUses         Int
  useCount        Int          @default(0)
  revokedAt       DateTime?
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  creator         DmIdentity   @relation("GroupInviteCreator", fields: [createdByUserId], references: [userId])

  @@index([conversationId])
}

model MessageReaction {
  id        Int        @id @default(autoincrement())
  messageId String
  userId    Int
  emoji     String
  createdAt DateTime   @default(now())
  message   Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      DmIdentity @relation(fields: [userId], references: [userId])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model MessageDeletion {
  id        Int      @id @default(autoincrement())
  messageId String
  userId    Int
  deletedAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model MessageReceipt {
  id          Int       @id @default(autoincrement())
  messageId   String
  userId      Int
  deliveredAt DateTime?
  readAt      DateTime?
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model WithdrawalRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  amount      String
  status      String    @default("pending")
  txHash      String?
  cawonce     Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@unique([userId, cawonce], map: "WithdrawalRequest_userId_cawonce_unique")
  @@index([userId, status])
  @@index([status])
  @@index([cawonce])
}

model ShortUrl {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(16)
  originalUrl String
  title       String?  @db.VarChar(255)
  description String?
  imageUrl    String?
  siteName    String?  @db.VarChar(100)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([originalUrl])
}

model Tip {
  id          Int      @id @default(autoincrement())
  senderId    Int
  recipientId Int
  amount      Int
  cawId       Int?
  cawonce     Int
  pending     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  caw         Caw?     @relation(fields: [cawId], references: [id])
  recipient   User     @relation("TipsReceived", fields: [recipientId], references: [tokenId])
  sender      User     @relation("TipsSent", fields: [senderId], references: [tokenId])

  @@index([senderId])
  @@index([senderId, recipientId, cawId])
  @@index([senderId, pending])
  @@index([recipientId])
  @@index([cawId])
  @@index([pending])
  @@index([recipientId, pending, createdAt])
}

model ChainData {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id           Int          @id @default(autoincrement())
  reporterId   Int
  postId       Int
  postAuthorId Int
  reason       ReportReason
  details      String?
  status       ReportStatus @default(PENDING)
  reviewedAt   DateTime?
  reviewedBy   String?
  resolution   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([postId])
  @@index([reporterId])
  @@index([reporterId, postId])
  @@index([postAuthorId])
  @@index([createdAt])
}

/// Audit trail for moderator-tier mutations (hide caw, ban user, etc.).
/// Append-only — never updated, never deleted. Lets admins answer "who
/// hid this caw and why" without grep-archaeology of server logs.
model ModeratorAction {
  id           Int      @id @default(autoincrement())
  /// Tokenid of the moderator who performed the action. NULL means the
  /// action was taken by the password-cookie admin (no wallet identity
  /// available in that path).
  actorTokenId Int?
  /// Free-form action verb: "hide_caw", "unhide_caw", "ban_user", etc.
  /// Kept as a string instead of an enum so we can add new verbs without
  /// migrations during early iteration.
  type         String
  targetCawId  Int?
  targetUserId Int?
  reason       String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("ModeratorActor", fields: [actorTokenId], references: [tokenId])

  @@index([actorTokenId, createdAt])
  @@index([type, createdAt])
  @@index([targetCawId])
  @@index([targetUserId])
}

model BugReport {
  id           Int          @id @default(autoincrement())
  type         String       @default("bug")
  userId       Int?
  username     String?
  stakedAmount String?
  description  String
  imageUrls    String?
  page         String?
  userAgent    String?
  status       ReportStatus @default(PENDING)
  resolution   String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([type])
}

model PriceSnapshot {
  id        Int      @id @default(autoincrement())
  token     String
  usdPrice  Float
  ethPrice  Float?
  createdAt DateTime @default(now())

  @@index([token, createdAt])
  @@index([createdAt])
}

/// Tracks every validator-submitted transaction for analytics
model ValidatorTx {
  id              Int      @id @default(autoincrement())
  txHash          String   @unique
  blockNumber     BigInt?
  txType          String   @default("processActions")
  actionCount     Int
  actionBreakdown Json?
  gasUsed         String
  gasPrice        String
  ethCost         String
  tipCaw          String
  tipEthValue     String
  profit          String
  validatorId     Int
  status          String   @default("confirmed")
  failReason      String?
  avgWaitMs       Int?
  sessionUser     String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([validatorId, createdAt])
  @@index([txType, createdAt])
}

/// Tracks every optimistic replication submission to the L2b archive.
/// Status transitions: confirmed → challenged → slashed (on fraud).
model ReplicationTx {
  id              Int      @id @default(autoincrement())
  txHash          String   @unique
  blockNumber     BigInt?
  checkpointId    Int
  endCheckpointId Int?
  actionCount     Int      @default(256)
  gasUsed         String
  gasPrice        String
  ethCost         String
  totalCost       String
  status          String   @default("confirmed")
  failReason      String?
  submitter       String?
  createdAt       DateTime @default(now())
  networkId       Int

  @@index([createdAt])
  @@index([submitter, createdAt])
  @@index([networkId, createdAt])
}

/// Admin-configurable validator settings (DB-backed, overrides env vars)
model ValidatorSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Coordinates the fraud-challenge pipeline across multiple validator nodes
/// that share a database. A lock is claimed via INSERT...ON CONFLICT DO NOTHING
/// before sending a challenge or calling resolveChallenge, so only one node
/// does the work. `expiresAt` lets stale locks (node crashed mid-call) be
/// reclaimed. `kind` scopes the lock to a specific pipeline stage so, for
/// example, the relay stage doesn't block the resolve stage.
model ChallengeLock {
  /// Composite natural key built as "{kind}:{submissionId}:{checkpointId}"
  /// so a single INSERT can claim atomically.
  key          String   @id
  kind         String
  submissionId BigInt
  checkpointId BigInt
  holder       String
  claimedAt    DateTime @default(now())
  expiresAt    DateTime
  outcome      String?
  txHash       String?

  @@index([kind, submissionId])
  @@index([expiresAt])
}

