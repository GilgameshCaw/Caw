model Client {
  id              Int       @id // clientId from chain
  ownerAddress    String
  feeAddress      String
  mintFee         String    @default("0") // Store as string for BigInt
  depositFee      String    @default("0")
  withdrawFee     String    @default("0")
  authFee         String    @default("0")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastSyncedAt    DateTime?
  lastSyncedBlock BigInt?
  // Block at which this client was created on-chain. Used as the L2 indexer's
  // historical scan lower bound so a fresh DB doesn't replay events from
  // before this client existed. Nullable for clients created before the
  // field was added — backend falls back to configured startBlock when null.
  // Once the on-chain CawClient struct carries this field, ChainSyncService
  // populates it from the contract. Until then it's manually seeded or
  // derived from the ClientCreated event block.
  creationBlock   BigInt?

  @@index([ownerAddress])
}

model ChainData {
  key       String   @id // e.g., "caw_eth_price", "gas_price"
  value     Json // Flexible storage for different data types
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
