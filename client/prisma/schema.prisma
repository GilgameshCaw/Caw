generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RawEvent {
  id              Int      @id @default(autoincrement())
  chainId         Int
  blockNumber     BigInt
  logIndex        Int
  transactionHash String
  parentHash      String
  data            Json
  topics          Json
  contractAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Action          Action[]

  @@unique([blockNumber, logIndex, transactionHash])
  @@index([chainId, blockNumber, logIndex])
}

model User {
  id                    Int            @id // Set to tokenId when creating user
  address               String         @default("")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  cawCount              Int            @default(0)
  followerCount         Int            @default(0)
  followingCount        Int            @default(0)
  image                 String?
  likeCount             Int            @default(0)
  tokenId               Int            @unique // Kept for backwards compatibility, always equals id
  username              String         @unique
  avatarUrl             String?
  bio                   String?
  coverPhotoUrl         String?
  displayName           String?
  location              String?
  profileUpdatePending  Boolean        @default(false)
  website               String?
  onboardingStep        Int            @default(0)
  lastStakedAt          DateTime?
  caws                  Caw[]
  followers             Follow[]       @relation("Follower")
  follows               Follow[]       @relation("Following")
  likes                 Like[]
  replies               Reply[]
  notificationsSent     Notification[] @relation("NotificationActor")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  scheduledCaws         ScheduledCaw[]
  dmIdentity            DmIdentity?
  onChainImages         OnChainImage[]
  tipsSent              Tip[]          @relation("TipsSent")
  tipsReceived          Tip[]          @relation("TipsReceived")

  @@index([address])
}

model Caw {
  id            Int            @id @default(autoincrement())
  userId        Int
  content       String
  action        ActionType
  createdAt     DateTime       @default(now())
  originalCawId Int?
  cawonce       Int
  commentCount  Int            @default(0)
  recawCount    Int            @default(0)
  likeCount     Int            @default(0)
  updatedAt     DateTime       @updatedAt
  hasImage      Boolean        @default(false)
  hasVideo      Boolean        @default(false)
  imageData     String?
  status        CawStatus      @default(SUCCESS)
  reason        String?
  videoData     String?
  viewCount     Int            @default(0)
  parent        Caw?           @relation("CawToRecaws", fields: [originalCawId], references: [id])
  recaws        Caw[]          @relation("CawToRecaws")
  user          User           @relation(fields: [userId], references: [tokenId])
  hashtags      CawHashtag[]
  likes         Like[]
  repliesOnThis Reply[]        @relation("RepliesOnCaw")
  isReplyTo     Reply[]        @relation("ReplyCaw")
  notifications Notification[]
  tips          Tip[]

  @@unique([userId, cawonce])
  @@index([userId, action, createdAt])
  @@index([originalCawId])
  @@index([originalCawId, action])
  @@index([status, userId])
}

model Like {
  userId    Int
  cawId     Int
  action    ActionType
  createdAt DateTime   @default(now())
  pending   Boolean    @default(false)
  updatedAt DateTime   @updatedAt
  id        Int        @id @default(autoincrement())
  caw       Caw        @relation(fields: [cawId], references: [id])
  user      User       @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId])
  @@index([cawId])
  @@index([cawId, action])
}

model Reply {
  id         Int      @id @default(autoincrement())
  userId     Int      // replier's tokenId
  cawId      Int      // the post being replied to
  replyCawId Int      // the caw that IS the reply (links to Caw.id)
  pending    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  caw        Caw      @relation("RepliesOnCaw", fields: [cawId], references: [id])
  replyCaw   Caw      @relation("ReplyCaw", fields: [replyCawId], references: [id])
  user       User     @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId, replyCawId])
  @@index([cawId])
  @@index([cawId, pending])
  @@index([userId])
}

model Follow {
  id          Int        @id @default(autoincrement())
  followerId  Int
  followingId Int
  action      ActionType @default(FOLLOW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  status      CawStatus  @default(SUCCESS)
  follower    User       @relation("Follower", fields: [followerId], references: [tokenId])
  following   User       @relation("Following", fields: [followingId], references: [tokenId])

  @@unique([followerId, followingId])
  @@index([followerId, status])
  @@index([followingId, status])
}

model TxQueue {
  id        Int      @id @default(autoincrement())
  payload   Json
  signedTx  String   @unique
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  senderId  Int
  reason    String?

  @@index([senderId, status])
}

model Action {
  id         Int        @id @default(autoincrement())
  rawEventId Int
  chainId    Int
  senderId   Int
  cawonce    Int
  actionType ActionType
  data       Json
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  rawEvent   RawEvent   @relation(fields: [rawEventId], references: [id])

  @@unique([chainId, senderId, cawonce])
}

model Hashtag {
  id         Int          @id @default(autoincrement())
  name       String       @unique
  usageCount Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  caws       CawHashtag[]

  @@index([name])
  @@index([usageCount])
}

model CawHashtag {
  id        Int      @id @default(autoincrement())
  cawId     Int
  hashtagId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  caw       Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([cawId, hashtagId])
  @@index([hashtagId])
  @@index([cawId])
}

model ScheduledCaw {
  id           Int      @id @default(autoincrement())
  userId       Int
  content      String
  scheduledAt  DateTime
  status       String   @default("pending")
  publishedId  Int?
  imageData    String?
  hasImage     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  signedAction Json?
  cawonce      Int?
  user         User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@index([status, scheduledAt])
  @@index([userId, status, cawonce])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  actorId   Int
  type      NotificationType
  cawId     Int?
  groupKey  String?
  isRead    Boolean          @default(false)
  hidden    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  actor     User             @relation("NotificationActor", fields: [actorId], references: [tokenId], onDelete: Cascade)
  caw       Caw?             @relation(fields: [cawId], references: [id], onDelete: Cascade)
  user      User             @relation("NotificationRecipient", fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, hidden, createdAt])
  @@index([userId, type])
  @@index([userId, actorId, type])
  @@index([groupKey])
  @@index([createdAt])
}

model DmIdentity {
  id            Int                       @id @default(autoincrement())
  userId        Int                       @unique
  walletAddress String
  publicKey     String                    // hex-encoded secp256k1 public key
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  conversations ConversationParticipant[]
  sentMessages  Message[]                 @relation("MessageSender")
  user          User                      @relation(fields: [userId], references: [tokenId])

  @@index([walletAddress])
}

model Conversation {
  id            String                    @id @default(uuid())
  type          ConversationType          @default(DM)
  creatorId     Int
  lastMessageAt DateTime?
  lastMessageId String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  participants  ConversationParticipant[]
  messages      Message[]

  @@index([lastMessageAt])
  @@index([creatorId])
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId String
  userId         Int
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  unreadCount    Int          @default(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  identity       DmIdentity   @relation(fields: [userId], references: [userId])

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id               String             @id @default(uuid())
  conversationId   String
  senderId         Int
  encryptedPayload String?            // null when deleted for everyone (tombstone)
  contentType      String             @default("text") // "text", "deleted"
  editHistory      String?            // encrypted JSON array of previous versions
  status           MessageStatus      @default(SENT)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  conversation     Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           DmIdentity         @relation("MessageSender", fields: [senderId], references: [userId])
  receipts         MessageReceipt[]
  deletions        MessageDeletion[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageDeletion {
  id        Int      @id @default(autoincrement())
  messageId String
  userId    Int
  deletedAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model MessageReceipt {
  id          Int       @id @default(autoincrement())
  messageId   String
  userId      Int
  deliveredAt DateTime?
  readAt      DateTime?
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model WithdrawalRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  amount      String
  status      String    @default("pending")
  txHash      String?
  cawonce     Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId, status])
  @@index([status])
  @@index([cawonce])
}

model ShortUrl {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(10)
  originalUrl String
  title       String?  @db.VarChar(255)
  description String?
  imageUrl    String?
  siteName    String?  @db.VarChar(100)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([originalUrl])
}

model OnChainImage {
  id          Int       @id @default(autoincrement())
  userId      Int
  txQueueId   Int?
  imageRef    String    @unique // Format: img:senderId:cawonce
  cawonce     Int
  base64Data  String    @db.Text // The actual image data
  status      CawStatus @default(PENDING)
  cawCost     Int       // CAW tokens paid for upload
  reason      String?   // Failure reason if status is FAILED
  postedAt    DateTime? // When this image was first used in a post
  ignored     Boolean   @default(false) // User dismissed the "not posted" badge
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@unique([userId, cawonce])
  @@index([userId, status])
  @@index([userId, postedAt, ignored])
  @@index([status])
  @@index([createdAt])
}

model Tip {
  id          Int      @id @default(autoincrement())
  senderId    Int
  recipientId Int
  amount      Int
  cawId       Int?
  cawonce     Int
  pending     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sender      User     @relation("TipsSent", fields: [senderId], references: [tokenId])
  recipient   User     @relation("TipsReceived", fields: [recipientId], references: [tokenId])
  caw         Caw?     @relation(fields: [cawId], references: [id])

  @@index([senderId])
  @@index([senderId, recipientId, cawId])
  @@index([senderId, pending])
  @@index([recipientId])
  @@index([cawId])
  @@index([pending])
}

enum ActionType {
  CAW
  LIKE
  UNLIKE
  RECAW
  FOLLOW
  UNFOLLOW
  WITHDRAW
  OTHER
}

enum CawStatus {
  SUCCESS
  PENDING
  FAILED
}

enum NotificationType {
  FOLLOW
  LIKE
  REPLY
  REPOST
  QUOTE
  MENTION
  TIP
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationType {
  DM
}

model Client {
  id                  Int      @id // clientId from chain
  ownerAddress        String
  feeAddress          String
  mintFee             String   @default("0") // Store as string for BigInt
  depositFee          String   @default("0")
  withdrawFee         String   @default("0")
  authFee             String   @default("0")
  replicationEnabled  Boolean  @default(false)
  replicationCount    Int      @default(0)
  replications        Json?    // Array of { eid: number, target: string }
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastSyncedAt        DateTime?
  lastSyncedBlock     BigInt?

  @@index([ownerAddress])
}

model ChainData {
  key       String   @id // e.g., "caw_eth_price", "gas_price"
  value     Json     // Flexible storage for different data types
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id            Int          @id @default(autoincrement())
  reporterId    Int          // The user who submitted the report (tokenId)
  postId        Int          // The caw being reported
  postAuthorId  Int          // The author of the reported post
  reason        ReportReason
  details       String?      // Optional additional details from reporter
  status        ReportStatus @default(PENDING)
  reviewedAt    DateTime?
  reviewedBy    String?      // Admin who reviewed (could be wallet address)
  resolution    String?      // Notes from admin review
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([postId])
  @@index([reporterId])
  @@index([reporterId, postId])
  @@index([postAuthorId])
  @@index([createdAt])
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

model BugReport {
  id          Int       @id @default(autoincrement())
  userId      Int?      // Reporter's tokenId (null if not signed in)
  username    String?
  stakedAmount String?  // Staked CAW amount as string
  description String
  imageUrls   String?   // Pipe-separated image URLs
  page        String?   // URL/route where the bug was encountered
  userAgent   String?
  status      ReportStatus @default(PENDING)
  resolution  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}
