enum OfferStatus {
  ACTIVE
  ACCEPTED
  CANCELLED
  EXPIRED
}

// Per-recipient "I dismissed this offer from my view" record. Distinct from
// MarketplaceOffer.status (which is mirrored from chain by MarketplaceIndexer
// and would get clobbered if we tried to overload it). One row per (offer,
// dismisser) so each owner of the targeted username can dismiss independently.
model MarketplaceOfferDismissal {
  id        Int              @id @default(autoincrement())
  offerId   Int
  userId    Int
  createdAt DateTime         @default(now())
  offer     MarketplaceOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@unique([offerId, userId])
  @@index([userId])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  cawId     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)
  caw       Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)

  @@unique([userId, cawId])
  @@index([userId, createdAt])
  @@index([cawId])
}

// Profile pin. One row per (user, pinned caw). Mirrors the Bookmark
// shape with one extra field — `pending` flag, same lifecycle as
// Like.pending: API sets pending=true on optimistic insert, indexer
// flips to false on confirm, tx-fail rollback deletes the row (for
// pi:) or flips pending back (for xpi:, where we kept the original).
//
// Cap: NOT enforced server-side. The read path (caws.ts profile feed)
// shows only the 3 most recently pinned. If parallel pin txs race
// past 3, the older ones simply never render until the user unpins
// one of the visible 3.
model PinnedCaw {
  id        Int      @id @default(autoincrement())
  userId    Int
  cawId     Int
  // True when an optimistic pin write has landed but the on-chain
  // action hasn't confirmed yet. Indexer flips to false on confirm.
  pending   Boolean  @default(false)
  // True when the user has submitted an unpin but the on-chain action
  // hasn't confirmed yet. The row still exists (so the indexer can
  // delete it on confirm), but read paths must suppress it. Set by
  // /api/actions on xpi:; cleared either by the indexer deleting the
  // row, or by a re-pin (pi:) on the same cawId.
  pendingUnpin Boolean @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)
  caw       Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)

  @@unique([userId, cawId])
  // Profile-feed read sorts by createdAt desc to surface the 3 most
  // recently pinned; this index makes that lookup index-only.
  @@index([userId, createdAt])
  @@index([cawId])
}

/// Indexed mirror of CawNameL2.sessions[owner][sessionKey] state.
/// Written by the event indexer listening for SessionCreated / SessionRevoked
/// on L2. Read by /api/actions to validate session-key-signed submissions
/// without a live RPC call per action.
model SessionKey {
  id             Int       @id @default(autoincrement())
  ownerAddress   String // lowercase owner (token owner)
  sessionAddress String // lowercase session key address
  expiry         BigInt // unix seconds, matches contract uint64
  scopeBitmap    Int // contract uint8, bit i = action type i allowed
  spendLimit     String // bigint as string (whole CAW tokens, not wei)
  spent          String    @default("0") // locally-tracked spend total
  revokedAt      DateTime? // set when SessionRevoked event indexed
  lastSyncedAt   DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([ownerAddress, sessionAddress])
  @@index([ownerAddress])
  @@index([sessionAddress])
}

/// Indexed mirror of CawNameL2.authenticated[clientId][tokenId] state.
/// Written by the event indexer listening for Authenticated on L2.
/// Auth is a one-way flag (once true, always true for that pair) — set
/// when the token's owner deposits CAW for this client.
model ClientAuth {
  id            Int      @id @default(autoincrement())
  clientId      Int
  tokenId       Int
  authenticated Boolean  @default(false)
  lastSyncedAt  DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([clientId, tokenId])
  @@index([tokenId])
}

/// X (Twitter) account link, scoped to a wallet address. The /api/verify/x
/// OAuth flow proves the wallet controls the X handle; we capture a bucketed
/// follower count once at link time (and on user-initiated refresh) and
/// discard the OAuth tokens.
///
/// Wallet-scoped (not per-User) because every CAW profile owned by the
/// linked wallet inherits the link. xUserId is X's stable id (handles can
/// change) and is the conflict key for first-link-wins enforcement at the
/// DB level. Per-profile show/hide is on User.xBadgeVisible.
///
/// Address is stored lowercased — read paths and write paths both
/// normalize so the unique key behaves like a case-insensitive index.
model WalletXLink {
  id                 Int      @id @default(autoincrement())
  address            String   @unique
  xUserId            String   @unique
  xHandle            String
  xFollowerBucket    Int?
  linkedAt           DateTime @default(now())
  followersUpdatedAt DateTime @default(now())

  @@index([xHandle])
}

/// Per-user CAW balance change ledger written by the StakeLedger
/// snapshotter. Mirrors CawProfileL2.cawOwnership state transitions
/// bit-for-bit using TS bigint. One row per touched user per action
/// (sender + recipient if any), plus rows for L1->L2 deposits and
/// withdrawals. Communal rewards are computed at query time from
/// RewardMultiplierSnapshot deltas, not stored as rows here.
///
/// All NUMERIC(78,0) values are stored as String to avoid precision
/// loss across the JSON layer — same pattern as User.onChainStakeWei.
model CawOwnershipSnapshot {
  id                  BigInt   @id @default(autoincrement())
  tokenId             Int
  blockNumber         BigInt
  blockTimestamp      DateTime
  txHash              String
  logIndex            Int
  actionIndex         Int?
  ownership           String
  multiplier          String
  balance             String
  delta               String
  reason              String // ACTION_SENDER | ACTION_RECIPIENT | DEPOSIT | WITHDRAW
  actionType          String? // CAW | LIKE | RECAW | FOLLOW | TIP | null for deposit/withdraw
  counterpartyTokenId Int?
  createdAt           DateTime @default(now())

  @@index([tokenId, blockTimestamp])
  @@index([blockTimestamp])
}

/// One row per global rewardMultiplier change. Used to attribute
/// communal rewards to a user across a window:
/// communal[user, t0..t1] = SUM over events e in window of
///   cawOwnership_at(user, e.timestamp) * (multiplierAfter - multiplierBefore) / 1e18
model RewardMultiplierSnapshot {
  blockNumber      BigInt
  txHash           String
  logIndex         Int
  actionIndex      Int
  blockTimestamp   DateTime
  multiplierBefore String
  multiplierAfter  String
  communalAmount   String
  /// Resolved action type that triggered this distribution (CAW,
  /// LIKE, RECAW, FOLLOW, TIP, OTHER). Lets the activity chart break
  /// down "CAW distributed to stakers" by action type at the system
  /// level. Nullable for legacy rows from before this column existed.
  actionType       String?

  @@id([blockNumber, logIndex, actionIndex])
  @@index([blockTimestamp])
}

/// Persisted running state of the StakeLedger snapshotter so a
/// process restart resumes without replaying from genesis.
model StakeLedgerState {
  clientId     Int      @id
  totalCaw     String
  multiplier   String
  lastBlock    BigInt
  lastLogIndex Int
  updatedAt    DateTime @default(now())
}

/// Latest cawOwnership[tokenId] mirroring contract state. Lets the
/// snapshotter cold-start without a full CawOwnershipSnapshot scan,
/// and gives the daily reconciler a cheap target to compare against
/// the on-chain cawOwnership(tokenId) read.
model CawOwnershipCurrent {
  tokenId   Int      @id
  ownership String
  updatedAt DateTime @default(now())
}
