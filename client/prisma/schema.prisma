generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RawEvent {
  id              Int      @id @default(autoincrement())
  chainId         Int
  blockNumber     BigInt
  logIndex        Int
  transactionHash String
  parentHash      String
  data            Json
  topics          Json
  contractAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Action          Action[]

  @@unique([blockNumber, logIndex, transactionHash])
  @@index([chainId, blockNumber, logIndex])
}

model User {
  id                    Int            @id // Set to tokenId when creating user
  address               String         @default("")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  cawCount              Int            @default(0)
  recawCount            Int            @default(0)  // recaws + quotes by this user
  followerCount         Int            @default(0)
  followingCount        Int            @default(0)
  image                 String?
  likeCount             Int            @default(0)
  tokenId               Int            @unique // Kept for backwards compatibility, always equals id
  username              String         @unique
  avatarUrl             String?
  defaultAvatarId       Int            @default(0) // 1-100; which default avatar to show when avatarUrl is null
  bio                   String?
  coverPhotoUrl         String?
  displayName           String?
  location              String?
  profileUpdatePending  Boolean        @default(false)
  profileSource         String         @default("onchain") // "onchain" or "offchain"
  website               String?
  onboardingStep        Int            @default(0)
  lastStakedAt          DateTime?
  pendingDepositAmount  String?           // wei amount as string, pending L1→L2 bridge
  lastViewedOffersAt    DateTime?         // When the user last viewed the My Offers tab
  caws                  Caw[]
  followers             Follow[]       @relation("Follower")
  follows               Follow[]       @relation("Following")
  likes                 Like[]
  replies               Reply[]
  notificationsSent     Notification[] @relation("NotificationActor")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  scheduledCaws         ScheduledCaw[]
  dmIdentity            DmIdentity?
  tipsSent              Tip[]          @relation("TipsSent")
  tipsReceived          Tip[]          @relation("TipsReceived")
  blocksGiven           Block[]        @relation("BlocksGiven")
  blocksReceived        Block[]        @relation("BlocksReceived")
  bookmarks             Bookmark[]

  @@index([address])
  @@index([cawCount, followerCount])
}

model Caw {
  id            Int            @id @default(autoincrement())
  userId        Int
  content       String
  action        ActionType
  createdAt     DateTime       @default(now())
  originalCawId Int?
  cawonce       Int
  commentCount  Int            @default(0)
  recawCount    Int            @default(0)
  likeCount     Int            @default(0)
  updatedAt     DateTime       @updatedAt
  hasImage      Boolean        @default(false)
  hasVideo      Boolean        @default(false)
  imageData     String?
  status        CawStatus      @default(SUCCESS)
  reason        String?
  videoData     String?
  viewCount     Int            @default(0)
  parent        Caw?           @relation("CawToRecaws", fields: [originalCawId], references: [id])
  recaws        Caw[]          @relation("CawToRecaws")
  user          User           @relation(fields: [userId], references: [tokenId])
  hashtags      CawHashtag[]
  likes         Like[]
  repliesOnThis Reply[]        @relation("RepliesOnCaw")
  isReplyTo     Reply[]        @relation("ReplyCaw")
  notifications Notification[]
  tips          Tip[]
  bookmarks     Bookmark[]
  bookmarkCount Int            @default(0)

  @@unique([userId, cawonce])
  @@index([userId, action, createdAt])
  @@index([originalCawId])
  @@index([originalCawId, action])
  @@index([status, userId])
}

model Like {
  userId    Int
  cawId     Int
  action    ActionType
  createdAt DateTime   @default(now())
  pending   Boolean    @default(false)
  updatedAt DateTime   @updatedAt
  id        Int        @id @default(autoincrement())
  caw       Caw        @relation(fields: [cawId], references: [id])
  user      User       @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId])
  @@index([cawId])
  @@index([cawId, action])
}

model Reply {
  id         Int      @id @default(autoincrement())
  userId     Int      // replier's tokenId
  cawId      Int      // the post being replied to
  replyCawId Int      // the caw that IS the reply (links to Caw.id)
  pending    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  caw        Caw      @relation("RepliesOnCaw", fields: [cawId], references: [id])
  replyCaw   Caw      @relation("ReplyCaw", fields: [replyCawId], references: [id])
  user       User     @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId, replyCawId])
  @@index([cawId])
  @@index([cawId, pending])
  @@index([userId])
}

model Follow {
  id          Int        @id @default(autoincrement())
  followerId  Int
  followingId Int
  action      ActionType @default(FOLLOW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  status      CawStatus  @default(SUCCESS)
  follower    User       @relation("Follower", fields: [followerId], references: [tokenId])
  following   User       @relation("Following", fields: [followingId], references: [tokenId])

  @@unique([followerId, followingId])
  @@index([followerId, status])
  @@index([followingId, status])
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blocker   User     @relation("BlocksGiven", fields: [blockerId], references: [tokenId])
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [tokenId])

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model TxQueue {
  id                   Int      @id @default(autoincrement())
  payload              Json
  signedTx             String   @unique
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  senderId             Int
  reason               String?
  // If non-null, the client claims a pending L1 deposit tx that should credit
  // this sender's balance once it lands on L2. Presence of this field causes
  // the validator to mark the row waiting_for_deposit without simulating,
  // and the DataCleaner watcher to promote it when L2 catches up.
  pendingDepositTxHash String?

  @@index([senderId, status])
}

model Action {
  id         Int        @id @default(autoincrement())
  rawEventId Int
  chainId    Int
  senderId   Int
  cawonce    Int
  actionType ActionType
  data       Json
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  rawEvent   RawEvent   @relation(fields: [rawEventId], references: [id])

  @@unique([chainId, senderId, cawonce])
}

model Hashtag {
  id         Int          @id @default(autoincrement())
  name       String       @unique
  usageCount Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  caws       CawHashtag[]

  @@index([name])
  @@index([usageCount])
}

model CawHashtag {
  id        Int      @id @default(autoincrement())
  cawId     Int
  hashtagId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  caw       Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([cawId, hashtagId])
  @@index([hashtagId])
  @@index([cawId])
}

model ScheduledCaw {
  id           Int      @id @default(autoincrement())
  userId       Int
  content      String
  scheduledAt  DateTime
  status       String   @default("pending")
  publishedId  Int?
  imageData    String?
  hasImage     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  signedAction Json?
  cawonce      Int?
  user         User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@index([status, scheduledAt])
  @@index([userId, status, cawonce])
}

model Notification {
  id            Int              @id @default(autoincrement())
  userId        Int
  actorId       Int
  type          NotificationType
  cawId         Int?
  offerId       Int?             // Links to MarketplaceOffer for OFFER notifications
  groupKey      String?
  isRead        Boolean          @default(false)
  hidden        Boolean          @default(false)
  // For ACTION_FAILED: the original failed action payload, sufficient to
  // reconstruct and retry the action. For other notification types, null.
  // Shape: { actionType, receiverId?, receiverCawonce?, text?, recipients?, amounts?, originalTxQueueId, reason }
  actionPayload Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  actor         User             @relation("NotificationActor", fields: [actorId], references: [tokenId], onDelete: Cascade)
  caw           Caw?             @relation(fields: [cawId], references: [id], onDelete: Cascade)
  offer         MarketplaceOffer? @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user          User             @relation("NotificationRecipient", fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, hidden, createdAt])
  @@index([userId, type])
  @@index([userId, actorId, type])
  @@index([groupKey])
  @@index([createdAt])
}

model DmIdentity {
  id            Int                       @id @default(autoincrement())
  userId        Int                       @unique
  walletAddress String
  publicKey     String                    // hex-encoded secp256k1 public key
  dmPrivacy     DmPrivacy                 @default(EVERYONE)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  conversations ConversationParticipant[]
  sentMessages  Message[]                 @relation("MessageSender")
  user          User                      @relation(fields: [userId], references: [tokenId])

  @@index([walletAddress])
}

model Conversation {
  id            String                    @id @default(uuid())
  type          ConversationType          @default(DM)
  creatorId     Int
  lastMessageAt DateTime?
  lastMessageId String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  participants  ConversationParticipant[]
  messages      Message[]

  @@index([lastMessageAt])
  @@index([creatorId])
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId String
  userId         Int
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  unreadCount    Int          @default(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  identity       DmIdentity   @relation(fields: [userId], references: [userId])

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id               String             @id @default(uuid())
  conversationId   String
  senderId         Int
  encryptedPayload String?            // null when deleted for everyone (tombstone)
  contentType      String             @default("text") // "text", "deleted"
  editHistory      String?            // encrypted JSON array of previous versions
  status           MessageStatus      @default(SENT)
  shadowBlocked    Boolean            @default(false) // hidden from recipient, visible to sender
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  conversation     Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           DmIdentity         @relation("MessageSender", fields: [senderId], references: [userId])
  receipts         MessageReceipt[]
  deletions        MessageDeletion[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageDeletion {
  id        Int      @id @default(autoincrement())
  messageId String
  userId    Int
  deletedAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model MessageReceipt {
  id          Int       @id @default(autoincrement())
  messageId   String
  userId      Int
  deliveredAt DateTime?
  readAt      DateTime?
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model WithdrawalRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  amount      String
  status      String    @default("pending")
  txHash      String?
  cawonce     Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId, status])
  @@index([status])
  @@index([cawonce])
}

model ShortUrl {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(10)
  originalUrl String
  title       String?  @db.VarChar(255)
  description String?
  imageUrl    String?
  siteName    String?  @db.VarChar(100)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([originalUrl])
}

model Tip {
  id          Int      @id @default(autoincrement())
  senderId    Int
  recipientId Int
  amount      Int
  cawId       Int?
  cawonce     Int
  pending     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sender      User     @relation("TipsSent", fields: [senderId], references: [tokenId])
  recipient   User     @relation("TipsReceived", fields: [recipientId], references: [tokenId])
  caw         Caw?     @relation(fields: [cawId], references: [id])

  @@index([senderId])
  @@index([senderId, recipientId, cawId])
  @@index([senderId, pending])
  @@index([recipientId])
  @@index([cawId])
  @@index([pending])
}

enum ActionType {
  CAW
  LIKE
  UNLIKE
  RECAW
  FOLLOW
  UNFOLLOW
  WITHDRAW
  OTHER
}

enum CawStatus {
  SUCCESS
  PENDING
  FAILED
}

enum NotificationType {
  FOLLOW
  LIKE
  REPLY
  REPOST
  QUOTE
  MENTION
  TIP
  OFFER
  OUTBID
  AUCTION_WON
  ACTION_FAILED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationType {
  DM
}

enum DmPrivacy {
  EVERYONE    // Anyone with DMs enabled can message me
  FOLLOWERS   // My followers + people I follow can message me
  FOLLOWING   // Only people I follow can message me
}

model Client {
  id                  Int      @id // clientId from chain
  ownerAddress        String
  feeAddress          String
  mintFee             String   @default("0") // Store as string for BigInt
  depositFee          String   @default("0")
  withdrawFee         String   @default("0")
  authFee             String   @default("0")
  replicationEnabled  Boolean  @default(false)
  replicationCount    Int      @default(0)
  replications        Json?    // Array of { eid: number, target: string }
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastSyncedAt        DateTime?
  lastSyncedBlock     BigInt?

  @@index([ownerAddress])
}

model ChainData {
  key       String   @id // e.g., "caw_eth_price", "gas_price"
  value     Json     // Flexible storage for different data types
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id            Int          @id @default(autoincrement())
  reporterId    Int          // The user who submitted the report (tokenId)
  postId        Int          // The caw being reported
  postAuthorId  Int          // The author of the reported post
  reason        ReportReason
  details       String?      // Optional additional details from reporter
  status        ReportStatus @default(PENDING)
  reviewedAt    DateTime?
  reviewedBy    String?      // Admin who reviewed (could be wallet address)
  resolution    String?      // Notes from admin review
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([postId])
  @@index([reporterId])
  @@index([reporterId, postId])
  @@index([postAuthorId])
  @@index([createdAt])
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  EXPLICIT
  ILLEGAL_HARMFUL
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

model BugReport {
  id          Int       @id @default(autoincrement())
  type        String    @default("bug") // "bug" or "feature"
  userId      Int?      // Reporter's tokenId (null if not signed in)
  username    String?
  stakedAmount String?  // Staked CAW amount as string
  description String
  imageUrls   String?   // Pipe-separated image URLs
  page        String?   // URL/route where the bug was encountered
  userAgent   String?
  status      ReportStatus @default(PENDING)
  resolution  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([type])
}

model PriceSnapshot {
  id         Int      @id @default(autoincrement())
  token      String   // "caw" or "eth"
  usdPrice   Float    // Price in USD
  ethPrice   Float?   // Price in ETH (for CAW only)
  createdAt  DateTime @default(now())

  @@index([token, createdAt])
  @@index([createdAt])
}

/// Tracks every validator-submitted transaction for analytics
model ValidatorTx {
  id          Int      @id @default(autoincrement())
  txHash      String   @unique
  blockNumber BigInt?
  txType      String   @default("processActions") // processActions | sessionRegister | sessionRevoke
  actionCount     Int                // Number of actions in the batch (0 for session txs)
  actionBreakdown Json?              // { CAW: 3, LIKE: 2, FOLLOW: 1, ... }
  gasUsed     String             // Actual gas used (from receipt)
  gasPrice    String             // Effective gas price (wei)
  ethCost     String             // gasUsed * gasPrice in wei
  tipCaw      String             // Total CAW tip earned from the batch
  tipEthValue String             // Tip converted to ETH (wei) at submission time
  profit      String             // tipEthValue - ethCost (can be negative)
  validatorId Int
  status      String   @default("confirmed") // confirmed | failed | reverted
  failReason  String?
  avgWaitMs   Int?               // Avg time from TxQueue.createdAt to submission
  sessionUser String?            // Address of user who requested the session (for session txs)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([validatorId, createdAt])
  @@index([txType, createdAt])
}

/// Tracks every replicateBatch submission
model ReplicationTx {
  id           Int      @id @default(autoincrement())
  txHash       String   @unique
  blockNumber  BigInt?
  clientId     Int
  destEid      Int                // LayerZero destination endpoint ID
  checkpointId Int
  actionCount  Int      @default(256)
  gasUsed      String
  gasPrice     String
  ethCost      String             // Gas cost in wei
  lzFee        String             // LayerZero native fee paid (wei)
  totalCost    String             // ethCost + lzFee
  status       String   @default("confirmed")
  failReason   String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([clientId, createdAt])
}

/// Admin-configurable validator settings (DB-backed, overrides env vars)
model ValidatorSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============================================
// MARKETPLACE
// ============================================

model MarketplaceListing {
  id              Int                  @id @default(autoincrement())
  listingId       Int                  @unique
  tokenId         Int
  seller          String
  listingType     MarketListingType
  paymentToken    String               // "ETH", "CAW", "WETH", "USDC", "USDT"
  paymentAddress  String
  startPrice      String
  endPrice        String?
  startTime       DateTime
  endTime         DateTime?
  status          MarketListingStatus  @default(ACTIVE)
  highestBid      String?
  highestBidder   String?
  username        String
  usernameLength  Int
  stakedCaw       String?
  txHash          String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  bids            MarketplaceBid[]
  sale            MarketplaceSale?

  @@index([status, createdAt])
  @@index([status, usernameLength])
  @@index([tokenId])
}

model MarketplaceBid {
  id          Int                  @id @default(autoincrement())
  listingId   Int
  bidder      String
  amount      String
  txHash      String?
  status      BidStatus            @default(ACTIVE)
  createdAt   DateTime             @default(now())
  listing     MarketplaceListing   @relation(fields: [listingId], references: [id])

  @@index([listingId, status])
  @@index([bidder])
}

model MarketplaceSale {
  id           Int                  @id @default(autoincrement())
  listingId    Int                  @unique
  buyer        String
  seller       String
  tokenId      Int
  price        String
  paymentToken String
  username     String
  txHash       String?
  createdAt    DateTime             @default(now())
  listing      MarketplaceListing   @relation(fields: [listingId], references: [id])

  @@index([createdAt])
  @@index([tokenId])
}

enum MarketListingType {
  FIXED
  DUTCH_AUCTION
  ENGLISH_AUCTION
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  WITHDRAWN
}

model MarketplaceOffer {
  id              Int                  @id @default(autoincrement())
  offerId         Int                  @unique // on-chain offer ID
  tokenId         Int
  offerer         String               // wallet address
  paymentToken    String               // "ETH", "CAW", "WETH", "USDC", "USDT"
  paymentAddress  String               // token contract address
  amount          String               // offer amount in wei
  expiry          DateTime
  status          OfferStatus          @default(ACTIVE)
  username        String
  txHash          String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  notifications   Notification[]

  @@index([tokenId, status])
  @@index([offerer, status])
  @@index([status, createdAt])
}

enum OfferStatus {
  ACTIVE
  ACCEPTED
  CANCELLED
  EXPIRED
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  cawId     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)
  caw       Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)

  @@unique([userId, cawId])
  @@index([userId, createdAt])
  @@index([cawId])
}

/// Indexed mirror of CawNameL2.sessions[owner][sessionKey] state.
/// Written by the event indexer listening for SessionCreated / SessionRevoked
/// on L2. Read by /api/actions to validate session-key-signed submissions
/// without a live RPC call per action.
model SessionKey {
  id             Int       @id @default(autoincrement())
  ownerAddress   String    // lowercase owner (token owner)
  sessionAddress String    // lowercase session key address
  expiry         BigInt    // unix seconds, matches contract uint64
  scopeBitmap    Int       // contract uint8, bit i = action type i allowed
  spendLimit     String    // bigint as string (whole CAW tokens, not wei)
  spent          String    @default("0") // locally-tracked spend total
  revokedAt      DateTime? // set when SessionRevoked event indexed
  lastSyncedAt   DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([ownerAddress, sessionAddress])
  @@index([ownerAddress])
  @@index([sessionAddress])
}

/// Indexed mirror of CawNameL2.authenticated[clientId][tokenId] state.
/// Written by the event indexer listening for Authenticated on L2.
/// Auth is a one-way flag (once true, always true for that pair) — set
/// when the token's owner deposits CAW for this client.
model ClientAuth {
  id            Int      @id @default(autoincrement())
  clientId      Int
  tokenId       Int
  authenticated Boolean  @default(false)
  lastSyncedAt  DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([clientId, tokenId])
  @@index([tokenId])
}
