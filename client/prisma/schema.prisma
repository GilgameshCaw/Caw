generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RawEvent {
  id              Int      @id @default(autoincrement())
  chainId         Int
  blockNumber     BigInt
  logIndex        Int
  transactionHash String
  parentHash      String
  data            Json
  topics          Json
  contractAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Action          Action[]

  @@unique([blockNumber, logIndex, transactionHash])
  @@index([chainId, blockNumber, logIndex])
}

model User {
  id                    Int                         @id // Set to tokenId when creating user
  address               String                      @default("")
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  cawCount              Int                         @default(0)
  recawCount            Int                         @default(0) // recaws + quotes by this user
  followerCount         Int                         @default(0)
  followingCount        Int                         @default(0)
  image                 String?
  // Cached like counters. Both maintained by CountManager on like/unlike/failure.
  // - likedCount         = likes this user has GIVEN (was the field formerly named `likeCount`).
  // - likesReceivedCount = total likes this user's caws have RECEIVED.
  // Both are read-and-self-heal: routes recompute from the Like table when displaying
  // and fire-and-forget an UPDATE if the cache drifts.
  likedCount            Int                         @default(0)
  likesReceivedCount    Int                         @default(0)
  tokenId               Int                         @unique // Kept for backwards compatibility, always equals id
  username              String                      @unique
  avatarUrl             String?
  defaultAvatarId       Int                         @default(0) // 1-100; which default avatar to show when avatarUrl is null
  bio                   String?
  coverPhotoUrl         String?
  displayName           String?
  location              String?
  profileUpdatePending  Boolean                     @default(false)
  profileSource         String                      @default("onchain") // "onchain" or "offchain"
  website               String?
  onboardingStep        Int                         @default(0)
  lastStakedAt          DateTime?
  pendingDepositAmount  String? // wei amount as string, pending L1→L2 bridge
  // Cached L2 on-chain CAW staked balance, refreshed by DataCleaner. Tier 2
  // of the "RPC out of API request handlers" refactor — see PROJECT_BACKLOG.md.
  // /api/users/by-token reads this directly instead of calling cawBalanceOf
  // on every request. Wei stored as a string so the JSON layer can pass it
  // around without precision loss.
  onChainStakeWei       String?
  onChainStakeUpdatedAt DateTime?
  lastViewedOffersAt    DateTime? // When the user last viewed the My Offers tab
  // X badge visibility per profile. The X link itself lives on
  // WalletXLink (one row per wallet) since proving control of an X
  // handle is a wallet-level fact — every CAW profile owned by that
  // wallet inherits the link. This boolean lets the user opt each
  // profile in or out of showing the badge. Default true so the
  // profile that initiated the OAuth flow wins by default; UI flips
  // sibling profiles to false at link time.
  xBadgeVisible         Boolean                     @default(true)
  // BCP-47 primary subtag (e.g. "en", "es"). Null = follow browser locale.
  // Used by FeedItem to decide whether to surface the inline Translate
  // affordance and (when autoTranslate=true) to auto-translate posts whose
  // detected source language differs.
  preferredLanguage     String?
  autoTranslate         Boolean                     @default(false)
  caws                  Caw[]
  followers             Follow[]                    @relation("Follower")
  follows               Follow[]                    @relation("Following")
  likes                 Like[]
  replies               Reply[]
  notificationsSent     Notification[]              @relation("NotificationActor")
  notificationsReceived Notification[]              @relation("NotificationRecipient")
  notificationGroups    NotificationGroup[]
  scheduledCaws         ScheduledCaw[]
  dmIdentity            DmIdentity?
  tipsSent              Tip[]                       @relation("TipsSent")
  tipsReceived          Tip[]                       @relation("TipsReceived")
  blocksGiven           Block[]                     @relation("BlocksGiven")
  blocksReceived        Block[]                     @relation("BlocksReceived")
  bookmarks             Bookmark[]
  pinnedCaws            PinnedCaw[]
  // Cached count of CONFIRMED pinned caws (pending=false). Maintained
  // by the same write paths that touch PinnedCaw — incremented when a
  // pending row flips to confirmed, decremented when a confirmed row
  // is deleted. Read by the FeedItem owner menu to grey out the "Pin"
  // option at 3/3. The cap is a client affordance, not a server
  // invariant — the read path filters to top-3 regardless.
  pinnedCawCount        Int                         @default(0)
  votes                 Vote[]
  offerDismissals       MarketplaceOfferDismissal[]
  // Moderation tier. USER is the default. MODERATOR can hide caws and
  // triage reports; ADMIN can do everything plus assign roles, validator
  // settings, RPC config, DB admin. Promotions go through
  // POST /api/admin/users/:tokenId/role.
  role                  UserRole                    @default(USER)
  moderatorActions      ModeratorAction[]           @relation("ModeratorActor")

  @@index([address])
  @@index([cawCount, followerCount])
  @@index([role])
}

model Caw {
  id             Int            @id @default(autoincrement())
  userId         Int
  content        String
  action         ActionType
  createdAt      DateTime       @default(now())
  originalCawId  Int?
  cawonce        Int
  commentCount   Int            @default(0)
  recawCount     Int            @default(0)
  likeCount      Int            @default(0)
  updatedAt      DateTime       @updatedAt
  hasImage       Boolean        @default(false)
  hasVideo       Boolean        @default(false)
  // Detected source language (BCP-47 primary subtag) populated lazily on
  // the first successful translate. Null = not yet detected; UI always
  // surfaces a manual Translate button in that case.
  sourceLanguage String?
  imageData      String?
  status         CawStatus      @default(SUCCESS)
  reason         String?
  videoData      String?
  viewCount      Int            @default(0)
  parent         Caw?           @relation("CawToRecaws", fields: [originalCawId], references: [id])
  recaws         Caw[]          @relation("CawToRecaws")
  user           User           @relation(fields: [userId], references: [tokenId])
  hashtags       CawHashtag[]
  likes          Like[]
  repliesOnThis  Reply[]        @relation("RepliesOnCaw")
  isReplyTo      Reply[]        @relation("ReplyCaw")
  notifications  Notification[]
  tips           Tip[]
  bookmarks      Bookmark[]
  bookmarkCount  Int            @default(0)
  poll           Poll?
  pinnedBy       PinnedCaw[]

  @@unique([userId, cawonce])
  @@index([userId, action, createdAt])
  @@index([status, createdAt])
  @@index([originalCawId])
  @@index([originalCawId, action])
  @@index([status, userId])
  // Covers the dominant profile-feed + main-feed query shape:
  // `where: { userId, status: 'SUCCESS' } orderBy: { createdAt: desc }`.
  // The existing `(userId, action, createdAt)` and `(status, userId)`
  // composites each handle two of the three predicates; this one closes
  // the index gap so Postgres can serve the query without a sort step.
  // Audit 2026-05-13.
  @@index([userId, status, createdAt])
}

// Poll attached to a Caw. Created in the same transaction as the Caw row by
// either the API submit path (optimistic) or the indexer (catch-up from a
// remote node), driven by a ::poll:opt1:opt2:...:: marker in the caw text.
//
// Options are stored positionally: votes target by optionIndex, never by
// option-text. Editing a poll isn't supported (matches "no caw edits").
//
// Per-option vote counts are derived at query time via Prisma groupBy on
// Vote (no denormalized counters that could drift). totalVotes IS
// denormalized — single atomic counter, cheap to keep accurate, and the
// "12 votes" badge reads it without a count query.
model Poll {
  id           Int      @id @default(autoincrement())
  cawId        Int      @unique
  /// When voting closes. Computed at indexer-write time from the caw's
  /// block timestamp plus the duration in the ::pd:<dur>:: marker
  /// sidecar. NULL means the poll has no expiry (legacy polls created
  /// before the duration sidecar was added).
  endsAt       DateTime?
  options      String[] // PG text[]; positional. ≤ 6 entries enforced at write time.
  // Optional per-option image URLs. Positional, parallel to `options` —
  // empty string in slot i means "no image for option i". Default to an
  // empty array so older Poll rows (created before images were added)
  // keep working without backfill. URLs point at the image-upload
  // endpoint's CDN path; same /uploads/images/... layout that media
  // attachments use. Off-chain only — the on-chain ::poll:...:: marker
  // stays text-only, so mirror nodes see the poll but not the images
  // unless they fetch from the original instance.
  optionImages String[] @default([])
  /// When true, voters can pick any subset of options (checkbox UI;
  /// each vote action toggles one option). Encoded on-chain via the
  /// `::pm::` marker sidecar. Default false = single-select (radio UI;
  /// each vote replaces the prior choice). Legacy polls created
  /// before the sidecar always parse as single-select.
  multiSelect  Boolean  @default(false)
  totalVotes   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  caw          Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@index([cawId])
}

// One Vote row per (poll, voter). Latest vote wins — when a user changes
// their mind, we UPDATE the existing row's optionIndex rather than
// inserting a new row. Unvote is implemented as deleting the row and
// decrementing Poll.totalVotes.
//
// `pending` mirrors the pattern in Like / Reply / Tip: the API writes the
// row optimistically, the indexer flips pending → false (or for unvote,
// deletes the row) when the on-chain action confirms. Failed actions get
// cleaned up by cleanupOptimisticRows in utils/txQueueFailure.ts.
//
// `cawonce` carries the OTHER action's cawonce so cleanupOptimisticRows
// can find the right pending vote row to roll back when its TxQueue entry
// fails — same pattern Tip uses.
model Vote {
  id          Int      @id @default(autoincrement())
  pollId      Int
  voterId     Int
  optionIndex Int
  cawonce     Int
  pending     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  poll        Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  voter       User     @relation(fields: [voterId], references: [tokenId])

  /// Uniqueness on (pollId, voterId, optionIndex) so multi-select polls
  /// can have multiple Vote rows per voter — one per picked option.
  /// Single-select polls still get one row per voter in practice
  /// because the FE only emits one vote action per voter (replaces on
  /// change); the broader uniqueness key just stops being the
  /// constraint enforced. Existing rows satisfy the new constraint
  /// because (pollId, voterId) was already unique and adding
  /// optionIndex preserves that.
  @@unique([pollId, voterId, optionIndex])
  @@index([pollId, optionIndex])
  @@index([voterId])
}

model Like {
  userId    Int
  cawId     Int
  action    ActionType
  createdAt DateTime   @default(now())
  pending   Boolean    @default(false)
  updatedAt DateTime   @updatedAt
  id        Int        @id @default(autoincrement())
  caw       Caw        @relation(fields: [cawId], references: [id])
  user      User       @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId])
  @@index([cawId])
  @@index([cawId, action])
}

model Reply {
  id         Int      @id @default(autoincrement())
  userId     Int // replier's tokenId
  cawId      Int // the post being replied to
  replyCawId Int // the caw that IS the reply (links to Caw.id)
  pending    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  caw      Caw  @relation("RepliesOnCaw", fields: [cawId], references: [id])
  replyCaw Caw  @relation("ReplyCaw", fields: [replyCawId], references: [id])
  user     User @relation(fields: [userId], references: [tokenId])

  @@unique([userId, cawId, replyCawId])
  @@index([cawId])
  @@index([cawId, pending])
  @@index([userId])
}

model Follow {
  id          Int        @id @default(autoincrement())
  followerId  Int
  followingId Int
  action      ActionType @default(FOLLOW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  status      CawStatus  @default(SUCCESS)
  follower    User       @relation("Follower", fields: [followerId], references: [tokenId])
  following   User       @relation("Following", fields: [followingId], references: [tokenId])

  @@unique([followerId, followingId])
  @@index([followerId, status])
  @@index([followingId, status])
  // Covers the home-feed "is this author in my follows?" check: the feed
  // join filters by `followerId == me, action='FOLLOW', status='SUCCESS'`,
  // which the existing `(followerId, status)` indexes only partially.
  // Audit 2026-05-13.
  @@index([followerId, action, status])
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blocker   User     @relation("BlocksGiven", fields: [blockerId], references: [tokenId])
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [tokenId])

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model TxQueue {
  id                   Int      @id @default(autoincrement())
  payload              Json
  // signedTx was @unique under the legacy 1-sig-per-action model. Batched
  // sigs reuse one ActionBatch signature across every row in the group, so
  // uniqueness is no longer true at the column level. Replaced with a
  // plain index — the single-action dedup path (POST /api/actions) catches
  // duplicates with a findFirst lookup that's still bounded by the index.
  signedTx             String
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  senderId             Int
  reason               String?
  // If non-null, the client claims a pending L1 deposit tx that should credit
  // this sender's balance once it lands on L2. Presence of this field causes
  // the validator to mark the row waiting_for_deposit without simulating,
  // and the DataCleaner watcher to promote it when L2 catches up.
  pendingDepositTxHash String?

  // Groups txqueue rows that share an ActionBatch signature. Adjacent rows
  // (in createdAt/cawonce order) with the same batchId are sent on-chain
  // as one signature group. signedTx must match across rows in the group —
  // it's the batch sig that covers all of them.
  batchId Int?

  // Denormalized cawonce from payload.data.cawonce. Backs the partial
  // unique index TxQueue_senderId_cawonce_active_unique (defined in
  // a raw migration since Prisma's @@unique can't express partial
  // constraints). Catches the same-sender-same-cawonce race at insert
  // time — duplicate gets a P2002, the API responds 409, the frontend
  // re-reads chain and re-signs. Replaces the CawonceReservation
  // system that didn't see actions submitted by other servers.
  cawonce Int?

  // Diagnostic provenance. clientVersion is the build-time git SHA from
  // the FE that submitted the action (X-Caw-Client-Version header).
  // clientOrigin is the browser-supplied Origin header — useful as we
  // expand to mirrors / FE-only peers that submit on behalf of users.
  // Both nullable so old rows + non-FE submitters (curl, scripts) are fine.
  clientVersion String?
  clientOrigin  String?

  @@index([senderId, status])
  @@index([batchId])
  @@index([signedTx])
}

model Action {
  id               Int        @id @default(autoincrement())
  rawEventId       Int
  chainId          Int
  senderId         Int
  cawonce          Int
  actionType       ActionType
  data             Json
  txHash           String?
  blockNumber      Int?
  submitterAddress String?
  validatorId      Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  rawEvent         RawEvent   @relation(fields: [rawEventId], references: [id])

  @@unique([chainId, senderId, cawonce])
  @@index([senderId])
  @@index([actionType, createdAt])
}

model Hashtag {
  id          Int          @id @default(autoincrement())
  // Canonical lowercase form — used for uniqueness, joins, route keys.
  name        String       @unique
  // Original casing as typed by the first author to use this hashtag.
  // Read paths prefer this when rendering; falls back to `name` when null
  // (older rows pre-dating this column).
  displayName String?
  usageCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  caws        CawHashtag[]

  @@index([name])
  @@index([usageCount])
}

model CawHashtag {
  id        Int      @id @default(autoincrement())
  cawId     Int
  hashtagId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  caw       Caw      @relation(fields: [cawId], references: [id], onDelete: Cascade)
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([cawId, hashtagId])
  @@index([hashtagId])
  @@index([cawId])
}

model ScheduledCaw {
  id           Int      @id @default(autoincrement())
  userId       Int
  content      String
  scheduledAt  DateTime
  status       String   @default("pending")
  publishedId  Int?
  imageData    String?
  hasImage     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  signedAction Json?
  cawonce      Int?
  threadId     String? // shared id across all chunks of one scheduled thread; null = single post
  threadIndex  Int? // 0-based position of this chunk within its thread
  threadTotal  Int? // total chunks in the thread
  user         User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@index([status, scheduledAt])
  @@index([userId, status, cawonce])
  @@index([threadId, threadIndex])
}

/// Persistent rollup bucket for notifications. Created lazily by the
/// notification write path: a new notification looks for an OPEN group
/// matching (userId, type, targetKey) — open means `isRead=false` AND
/// `lastEventAt` within the last 15 minutes — and joins it if found,
/// or starts a fresh group otherwise. The notifications-list read
/// path queries this table directly so rollup is O(group page size),
/// not O(raw notifications).
///
/// "targetKey" semantics per type:
///   LIKE / REPOST / QUOTE / REPLY / TIP / MENTION → cawId as string
///   OFFER → tokenId as string
///   FOLLOW → null (one global follow bucket per user)
///   ACTION_FAILED → null (each failure is its own row, ungrouped)
///
/// Marking a group read closes it: the next event on the same target
/// starts a fresh group so users can see "5 new likes since last
/// time" instead of one ever-growing rollup. A group stays open
/// indefinitely while unread — no time-based closure.
model NotificationGroup {
  id                   Int      @id @default(autoincrement())
  userId               Int
  type                 NotificationType
  /// Disambiguator within (userId, type). String so we can stuff
  /// cawId / offerId / etc. into the same column without per-type
  /// joins; null means "global for this type".
  targetKey            String?
  openedAt             DateTime @default(now())
  /// Updated whenever a notification is added to this group. Drives
  /// the order on the feed (DESC).
  lastEventAt          DateTime @default(now())
  isRead               Boolean  @default(false)
  /// Quick pointer to the most-recent member for renderer lead
  /// actor / caw thumbnail / offer payload. Updated on every join.
  latestNotificationId Int
  /// Confirmed-row count for the rollup. Updated atomically with
  /// notification inserts inside the same transaction.
  count                Int      @default(1)
  user                 User     @relation(fields: [userId], references: [tokenId], onDelete: Cascade)
  notifications        Notification[]

  /// Two read indexes:
  ///   - feed read: ORDER BY lastEventAt DESC over (userId)
  ///   - open-group lookup / atomic upsert: partial unique index on
  ///     (userId, type, COALESCE(targetKey,'')) WHERE isRead=false
  ///     (hand-rolled in migration; Prisma can't express partial uniques)
  @@index([userId, lastEventAt])
  @@index([userId, type, targetKey, isRead, lastEventAt])
}

model Notification {
  id            Int               @id @default(autoincrement())
  userId        Int
  actorId       Int
  type          NotificationType
  cawId         Int?
  offerId       Int? // Links to MarketplaceOffer for OFFER notifications
  groupKey      String?
  /// Persistent NotificationGroup this row belongs to. Null only for
  /// rows created before the group-table migration; backfill flips
  /// them to a per-row synthetic group in the migration.
  groupId       Int?
  isRead        Boolean           @default(false)
  hidden        Boolean           @default(false)
  // For ACTION_FAILED: the original failed action payload, sufficient to
  // reconstruct and retry the action. For other notification types, null.
  // Shape: { actionType, receiverId?, receiverCawonce?, text?, recipients?, amounts?, originalTxQueueId, reason }
  actionPayload Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  actor         User              @relation("NotificationActor", fields: [actorId], references: [tokenId], onDelete: Cascade)
  caw           Caw?              @relation(fields: [cawId], references: [id], onDelete: Cascade)
  offer         MarketplaceOffer? @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user          User              @relation("NotificationRecipient", fields: [userId], references: [tokenId], onDelete: Cascade)
  group         NotificationGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  // Note: the previous standalone @@index([createdAt]) was dropped — every
  // real query path filters by userId first, and the userId-prefixed
  // composites above already handle every observed read. The lone-column
  // index just cost write overhead on this append-heavy table. Audit 2026-05-13.

  @@index([userId, isRead, createdAt])
  @@index([userId, hidden, createdAt])
  @@index([userId, type])
  @@index([userId, actorId, type])
  @@index([groupKey])
  /// Lets the notifications-list GROUP BY query in
  /// api/routes/notifications.ts use an index-only scan to bucket a
  /// user's notifications by groupKey. Without this, fetching the
  /// notifications page for users with thousands of rows did a full
  /// scan + HashAggregate (~hundreds of ms for the 4K-row heavy users
  /// on test.caw.social).
  @@index([userId, groupKey, createdAt])
}

model DmIdentity {
  id                 Int                       @id @default(autoincrement())
  userId             Int                       @unique
  walletAddress      String
  publicKey          String // hex-encoded secp256k1 public key
  // Wallet-signed proof that walletAddress authorized publicKey as its
  // DM signing key. The wallet personal_signs:
  //   "CAW DM identity\nuserId:<id>\npublicKey:<hex>"
  // and the result lives here. Cross-instance identity-relay forwards
  // this so peer mirrors can verify the (userId, publicKey, walletAddress)
  // triple without trusting the source instance's claim. Optional during
  // the migration window; required for newly-registered identities once
  // the FE update lands.
  walletProof        String?
  dmPrivacy          DmPrivacy                 @default(EVERYONE)
  // Per-user customization for the 5-emoji quick-reaction strip on DMs.
  // Empty array = use server defaults; otherwise expected to hold exactly
  // five emojis. We don't enforce length at the column level — UI clamps.
  defaultDmReactions String[]                  @default([])
  // Opt-out for direct add-to-group. Hitting an invite URL is explicit
  // consent and bypasses this gate.
  allowGroupInvites  Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  conversations      ConversationParticipant[]
  sentMessages       Message[]                 @relation("MessageSender")
  reactions          MessageReaction[]
  recipientPayloads  MessageRecipientPayload[]
  invitesCreated     GroupInvite[]             @relation("GroupInviteCreator")
  user               User                      @relation(fields: [userId], references: [tokenId])

  @@index([walletAddress])
}

model Conversation {
  id            String                    @id @default(uuid())
  type          ConversationType          @default(DM)
  creatorId     Int
  // Group-only metadata. Both null on DM rows.
  name          String?
  avatarUrl     String?
  lastMessageAt DateTime?
  lastMessageId String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  participants  ConversationParticipant[]
  messages      Message[]
  invites       GroupInvite[]

  // Conversations are almost always reached via ConversationParticipant
  // (userId filter), not by a global lastMessageAt sort, so the
  // standalone @@index([lastMessageAt]) was dropped. Audit 2026-05-13.
  @@index([creatorId])
}

model ConversationParticipant {
  id             Int                           @id @default(autoincrement())
  conversationId String
  userId         Int
  joinedAt       DateTime                      @default(now())
  lastReadAt     DateTime?
  unreadCount    Int                           @default(0)
  // Inbox segregation. ACCEPTED for existing rows + for participants who
  // initiated the conversation; REQUEST for an inbound DM where the
  // recipient has no consent baseline (no prior outbound, no follow
  // either way) — those land in the Requests tab. Flips to ACCEPTED on
  // first reply or explicit accept. BLOCKED mirrors Block table.
  status         ConversationParticipantStatus @default(ACCEPTED)
  // Group role. OWNER = can add/remove/rename/mint-invite. Cap of 1
  // owner per group enforced at the service layer (transfer on leave).
  role           ConversationParticipantRole   @default(MEMBER)
  // Removed-or-left timestamp. NULL = active. The participant lookup
  // for write paths MUST add `leftAt IS NULL` so removed members
  // can't send/react/edit. Keeping the row preserves system-message
  // attribution and unread-count history.
  leftAt         DateTime?
  conversation   Conversation                  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  identity       DmIdentity                    @relation(fields: [userId], references: [userId])

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@index([userId, status])
  @@index([conversationId, leftAt])
  // DM inbox queries filter by all three: userId + leftAt IS NULL +
  // optional status='REQUEST' for the Requests tab. None of the existing
  // composites cover the multi-filter. Runs on every DM inbox load.
  // Audit 2026-05-13.
  @@index([userId, leftAt, status])
}

enum ConversationParticipantStatus {
  ACCEPTED
  REQUEST
  BLOCKED
}

model Message {
  id                String                    @id @default(uuid())
  conversationId    String
  senderId          Int
  // null on group rows (per-recipient ciphertext lives in
  // MessageRecipientPayload), null on system rows, null when deleted
  // for everyone (tombstone), set on DM rows.
  encryptedPayload  String?
  contentType       String                    @default("text") // "text", "deleted", "system:created", "system:added", "system:removed", "system:left", "system:renamed", "system:avatarChanged", "system:ownerTransferred"
  editHistory       String? // encrypted JSON array of previous versions
  // System-event metadata (added/removed userIds, oldName/newName, ...).
  // Null on every non-system row.
  systemPayload     Json?
  status            MessageStatus             @default(SENT)
  shadowBlocked     Boolean                   @default(false) // hidden from recipient, visible to sender
  // Inner sender signature over the message envelope. The FE signs
  //   keccak256(encryptedPayload || senderId || recipientId
  //             || conversationId || contentType || timestamp)
  // with the user's DmIdentity secp256k1 private key (which is itself
  // wallet-derived). Receivers recover the address and check it matches
  // DmIdentity.walletAddress for senderId — closes the cross-instance
  // forgery vector where any registered relay node could put words in
  // any user's mouth. NULL on legacy rows + the FE migration window;
  // verifiedSender below tracks the outcome so renderers don't have to
  // re-recover.
  senderSig         String?
  // Whether the inner sig recovered to the wallet address registered
  // for senderId on receive. Indexed messages without senderSig (legacy
  // / migration window) get verifiedSender = null. Receivers stamp this
  // on the way in (both /api/dm/messages and /api/dm/relay) so badge +
  // thread-render decisions don't redo the recovery on every read.
  verifiedSender    Boolean?
  // Cross-node relay dedup. Home node generates a UUID per relayed
  // message; receivers reject replays via the partial unique index
  // (NULL for any message that was never relayed, e.g. pre-relay rows).
  relayId           String?                   @unique
  // Self-reference for replies. SetNull (not Cascade) so deleting a parent
  // doesn't delete every reply — replies just lose their thread anchor and
  // the UI falls back to "Original message unavailable".
  replyToMessageId  String?
  replyTo           Message?                  @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies           Message[]                 @relation("MessageReplies")
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  conversation      Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            DmIdentity                @relation("MessageSender", fields: [senderId], references: [userId])
  receipts          MessageReceipt[]
  deletions         MessageDeletion[]
  reactions         MessageReaction[]
  recipientPayloads MessageRecipientPayload[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToMessageId])
}

// Sealed-per-recipient ciphertext for group messages. One row per
// (message, active recipient including sender). For DM rows this table
// is unused — DM ciphertext stays on Message.encryptedPayload.
model MessageRecipientPayload {
  id               BigInt     @id @default(autoincrement())
  messageId        String
  recipientUserId  Int
  encryptedPayload String
  createdAt        DateTime   @default(now())
  message          Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient        DmIdentity @relation(fields: [recipientUserId], references: [userId], onDelete: Cascade)

  @@unique([messageId, recipientUserId])
  @@index([recipientUserId])
}

model GroupInvite {
  id              String       @id @default(uuid())
  token           String       @unique
  conversationId  String
  createdByUserId Int
  createdAt       DateTime     @default(now())
  expiresAt       DateTime
  maxUses         Int
  useCount        Int          @default(0)
  revokedAt       DateTime?
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  creator         DmIdentity   @relation("GroupInviteCreator", fields: [createdByUserId], references: [userId])

  @@index([conversationId])
}

// Plaintext reactions on a DM. Unlike the message body, the emoji isn't
// encrypted: the server doesn't need to read the message to know "user X
// reacted with ❤️", and keeping reactions cleartext avoids a per-recipient
// ciphertext fan-out on every reaction tap. Both peers see them; the
// server-as-adversary already knows who is talking to whom.
model MessageReaction {
  id        Int        @id @default(autoincrement())
  messageId String
  userId    Int
  emoji     String // Unicode emoji string (e.g. "❤️", "🌙")
  createdAt DateTime   @default(now())
  message   Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      DmIdentity @relation(fields: [userId], references: [userId])

  // Same user can stack different emojis on one message but can't double-
  // react with the same emoji. Toggling re-uses this constraint as a
  // delete-on-second-tap signal.
  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model MessageDeletion {
  id        Int      @id @default(autoincrement())
  messageId String
  userId    Int
  deletedAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model MessageReceipt {
  id          Int       @id @default(autoincrement())
  messageId   String
  userId      Int
  deliveredAt DateTime?
  readAt      DateTime?
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model WithdrawalRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  amount      String
  status      String    @default("pending")
  txHash      String?
  cawonce     Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId, status])
  @@index([status])
  @@index([cawonce])
}

model ShortUrl {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(16)
  originalUrl String
  title       String?  @db.VarChar(255)
  description String?
  imageUrl    String?
  siteName    String?  @db.VarChar(100)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([originalUrl])
}

model Tip {
  id          Int      @id @default(autoincrement())
  senderId    Int
  recipientId Int
  amount      Int
  cawId       Int?
  cawonce     Int
  pending     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sender      User     @relation("TipsSent", fields: [senderId], references: [tokenId])
  recipient   User     @relation("TipsReceived", fields: [recipientId], references: [tokenId])
  caw         Caw?     @relation(fields: [cawId], references: [id])

  @@index([senderId])
  @@index([senderId, recipientId, cawId])
  @@index([senderId, pending])
  @@index([recipientId])
  @@index([cawId])
  @@index([pending])
  // Covers the "tips received on profile" view: filter by recipientId +
  // pending=false, sort by createdAt desc. Existing indexes only handle
  // pieces of this. Audit 2026-05-13.
  @@index([recipientId, pending, createdAt])
}

